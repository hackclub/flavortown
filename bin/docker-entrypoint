#!/bin/bash -e

# Enable jemalloc for reduced memory usage and latency.
if [ -z "${LD_PRELOAD+x}" ]; then
    LD_PRELOAD=$(find /usr/lib -name libjemalloc.so.2 -print -quit)
    export LD_PRELOAD
fi

if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  # If running the rails server then create or migrate existing database...
  ./bin/rails db:prepare

  # ...and background the slow avif conversion task.
  nohup ./bin/rake assets:avif >> log/avif_conversion.log 2>&1 &

  # Warm up Ferret search index (this only runs on records that need it & is heavy only the first time it runs)
  if [ "$FERRET" = "true" ]; then
    ./bin/rails runner "Rails.application.eager_load!; Ferret.embed_all!"
  fi
fi

exec "${@}"
