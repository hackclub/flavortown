<div class="shop-item-card__image">
  <%= image_tag component.image_url, alt: "#{component.name} image", class: "rounded-lg w-full h-auto object-scale-down aspect-square max-h-48" %>
  <%= component.lock_overlay_html %>
</div>
<div class="shop-item-card__content">
  <h4 class="shop-item-card__title"><%= component.name %></h4>
  <div class="shop-item-card__description"><%= component.md(component.description) %></div>
  <%= component.achievement_requirement_html %>

  <% if component.show_primary_highlight? %>
    <% highlight = component.primary_highlight %>
    <div class="shop-item-card__highlight-tag shop-item-card__highlight-tag--<%= highlight[:type] %>">
      <%= highlight[:text] %>
    </div>
  <% end %>

  <% if component.show_secondary_highlight? %>
    <% secondary = component.secondary_highlight %>
    <div class="shop-item-card__highlight-tag shop-item-card__highlight-tag--limited">
      <span class="shop-item-card__highlight-label"><%= secondary[:label] %></span>
      <span class="shop-item-card__highlight-timer"><%= secondary[:text] %></span>
    </div>
  <% end %>

  <% if component.show_stock_status? %>
    <div class="shop-item-card__stock-meta">
      <%= component.stock_status_text %>
    </div>
  <% end %>

  <% if component.enabled_until.present? %>
    <div class="shop-item-card__enabled-until">
      Here until <%= component.enabled_until.strftime("%b %d, %Y") %>
    </div>
  <% end %>

  <div class="shop-item-card__details">
    <span class="shop-item-card__hours">⟩ <%= component.hours %> hours</span>
    <div class="shop-item-card__prices">
      <% if component.on_sale && component.original_price %>
        <span class="shop-item-card__original-price">🍪<span class="shop-item-card__strikethrough"><%= number_to_currency(component.original_price, precision: 0).delete('$') %></span></span>
      <% end %>
      <span class="shop-item-card__price"><%= number_to_currency(component.display_price, precision: 0).gsub('$', '🍪') %></span>
      <% if component.show_sale_badge? %>
        <span class="shop-item-card__sale-chip"><%= component.sale_percentage_text %></span>
      <% end %>
    </div>
  </div>
</div>
