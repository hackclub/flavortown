<div class="comic-card">
  <h1 class="comic-card__caption"><%= caption %></h1>

  <div class="comic-card__frame"
       data-controller="card-sound modal"
       data-action="click->card-sound#playSound click->modal#open"
       data-modal-target-value="<%= modal_id %>">
    <%= image_tag image_url,
      alt: alt,
      loading: "lazy",
      decoding: "async" %>
    <% if step_num.present? %>
      <div class="comic-card__step-num">
        <%= step_num %>
      </div>
    <% end %>
  </div>

  <% modal_id = @modal_id %>

  <%= render ModalComponent.new(id: @modal_id, title: modal_title, description: modal_text_html) do |modal| %>
    <% modal.with_close_button %>
  <% end %>
</div>
