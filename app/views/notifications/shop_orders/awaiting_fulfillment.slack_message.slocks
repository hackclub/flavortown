header "📦 Order ##{order.id} Approved!"

section "Your order has been approved and is awaiting fulfillment.", markdown: true

section "Order Details:",
  fields: [
    mrkdwn_text("*Order ID:* #{order.id}"),
    mrkdwn_text("*Item:* #{order.shop_item.name}"),
    mrkdwn_text("*Quantity:* #{order.quantity}"),
    mrkdwn_text("*Total:* 🍪 #{order.total_cost}"),
  ]

if order.tracking_number.present?
  if order.tracking_number.start_with?("pkg!", "ltr!")
    section "*Tracking:* <https://mail.hackclub.com/#{order.tracking_number}|#{order.tracking_number}>", markdown: true
  else
    section "*Tracking:* #{order.tracking_number}", markdown: true
  end
end

divider

context [
  mrkdwn_text("We'll notify you when your order ships. Thank you for your patience!")
]
