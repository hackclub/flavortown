header "Physics Lab Sidequest Entry Not Approved"

section "Your project *#{entry.project.title}* wasn't approved for the Physics Lab sidequest.", markdown: true

if entry.rejection_message.present?
  section "*Reason:* #{entry.rejection_message}", markdown: true
else
  section "Make sure your project is clearly physics related, then try again.", markdown: true
end

divider

context [
  mrkdwn_text("Questions? Reach out in #flavortown-help or DM @Carlson on Slack")
]