header ":noooovanish: Rusty Frontend Sidequest Entry Rejected"

section "Your project *#{entry.project.title}* wasn't approved for the Rusty Frontend sidequest. :pensive-wobble:", markdown: true

if entry.rejection_message.present?
  section "*Reason:* #{entry.rejection_message}", markdown: true
else
  section "Feel free to do appropriate changes and try again!", markdown: true
end

divider

context [
  mrkdwn_text("Questions? Reach out in #flavortown-help")
]
