        </div>

        <div class="super-mega-dashboard__card">
          <h3>Expenses $ per hour <span id="expenses-dollars-per-hour-formula">ⓘ</span></h3>
          <div class="super-mega-dashboard__stats">
            <div class="super-mega-dashboard__stat">
              <span class="super-mega-dashboard__stat--value"><%= @expenses_dollars_per_hour.round(2) %></span>
              <span class="super-mega-dashboard__stat--label">$/hr</span>
            </div>
          </div>
        </div>

        <div class="super-mega-dashboard__card">
          <h3>Cookie Utilization Ratio</h3>
          <div class="super-mega-dashboard__stats">
            <div class="super-mega-dashboard__stat">
              <span class="super-mega-dashboard__stat--value"><%= @cookie_utilization_percentage %>%</span>
              <span class="super-mega-dashboard__stat--label">Utilization</span>
            </div>
          </div>
        </div>
