<div class="super-mega-dashboard__dashboard">
  <div class="super-mega-dashboard__header super-mega-dashboard__header--sidequests">
    <h2>Sidequests Overview</h2>
    <%= link_to "View Sidequest Entries →", admin_sidequest_entries_path, class: "super-mega-link" %>
  </div>

  <div class="super-mega-dashboard__cards super-mega-dashboard__cards--sidequests">
    <div class="super-mega-dashboard__card">
      <h3>Queue + Velocity</h3>
      <div class="super-mega-dashboard__stats super-mega-dashboard__stats--sidequests">
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value yellow"><%= @sidequest_totals[:pending] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Pending</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value green"><%= @sidequest_totals[:approved] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Approved</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value red"><%= @sidequest_totals[:rejected] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Rejected</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value blue"><%= @sidequest_totals[:submitted_today] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Submitted Today</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value purple"><%= @sidequest_totals[:submitted_7d] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Submitted 7d</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value"><%= @sidequest_totals[:approval_rate] || 0 %>%</span>
          <span class="super-mega-dashboard__stat--label">Approval Rate</span>
        </div>
      </div>
      <% if @sidequest_totals[:oldest_pending_at].present? %>
        <p class="super-mega-dashboard__sidequest-oldest">
          Oldest pending: <%= time_ago_in_words(@sidequest_totals[:oldest_pending_at]) %> ago
        </p>
      <% end %>
    </div>

    <div class="super-mega-dashboard__card">
      <h3>Sidequest Submission Breakdown</h3>
      <% if @sidequest_submissions_breakdown.present? %>
        <div class="super-mega-dashboard__sidequest-pie-wrap">
          <canvas id="sidequestSubmissionsPieChart" height="220"></canvas>
        </div>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
            const initPie = function() {
              const canvas = document.getElementById('sidequestSubmissionsPieChart');
              if (!canvas) return;

              if (window.sidequestSubmissionsPieInstance) {
                window.sidequestSubmissionsPieInstance.destroy();
              }

              const entries = <%= raw @sidequest_submissions_breakdown.to_json %>;
              const labels = Object.keys(entries);
              const values = Object.values(entries);

              if (labels.length === 0) return;

              const palette = [
                '#3b82f6', '#10b981', '#f59e0b', '#ef4444',
                '#8b5cf6', '#14b8a6', '#f97316', '#6366f1'
              ];

              window.sidequestSubmissionsPieInstance = new Chart(canvas, {
                type: 'pie',
                data: {
                  labels: labels,
                  datasets: [{
                    data: values,
                    backgroundColor: labels.map(function(_l, i) { return palette[i % palette.length]; }),
                    borderColor: '#ffffff',
                    borderWidth: 2
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                    legend: {
                      position: 'bottom',
                      labels: {
                        boxWidth: 12,
                        padding: 10
                      }
                    },
                    tooltip: {
                      callbacks: {
                        label: function(context) {
                          const value = context.raw || 0;
                          const total = values.reduce(function(sum, n) { return sum + n; }, 0);
                          const pct = total > 0 ? ((value / total) * 100).toFixed(1) : '0.0';
                          return context.label + ': ' + value + ' (' + pct + '%)';
                        }
                      }
                    }
                  }
                }
              });
            };

            if (window.Chart) {
              initPie();
              return;
            }

            const script = document.createElement('script');
            script.src = 'https://cdn.jsdelivr.net/npm/chart.js';
            script.onload = initPie;
            document.head.appendChild(script);
          });
        </script>
      <% else %>
        <p class="fraud-stats-error">No sidequest submissions yet.</p>
      <% end %>
    </div>

    <div class="super-mega-dashboard__card">
      <h3>Shipped Project Coverage</h3>
      <div class="super-mega-dashboard__stats super-mega-dashboard__stats--sidequests">
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value blue"><%= @sidequest_totals[:shipped_projects_count] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">Projects Shipped</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value purple"><%= @sidequest_totals[:shipped_projects_with_sidequest_submission_count] || 0 %></span>
          <span class="super-mega-dashboard__stat--label">With Sidequest Submission</span>
        </div>
        <div class="super-mega-dashboard__stat">
          <span class="super-mega-dashboard__stat--value green"><%= @sidequest_totals[:shipped_projects_with_sidequest_submission_pct] || 0 %>%</span>
          <span class="super-mega-dashboard__stat--label">Coverage</span>
        </div>
      </div>
    </div>

    <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
      <h3>Sidequest Trends (30d)</h3>
      <% if @sidequest_trend_data.present? %>
        <div class="sidequest-trend-graph">
          <canvas id="sidequestTrendChart" height="300"></canvas>
        </div>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
            function loadChart(callback) {
              if (window.Chart) return callback();
              const script = document.createElement('script');
              script.src = 'https://cdn.jsdelivr.net/npm/chart.js';
              script.onload = callback;
              document.head.appendChild(script);
            }

            loadChart(function() {
              const ctx = document.getElementById('sidequestTrendChart');
              if (!ctx) return;

              if (window.sidequestTrendChartInstance) {
                window.sidequestTrendChartInstance.destroy();
              }

              const raw = <%= raw @sidequest_trend_data.to_json %>;
              const dates = Object.keys(raw).sort();
              const labels = dates.map(function(d) {
                const date = new Date(d);
                return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
              });

              const submitted = dates.map(function(d) { return raw[d].submitted || 0; });
              const shippedProjects = dates.map(function(d) { return raw[d].shipped_projects || 0; });
              const approved = dates.map(function(d) { return raw[d].approved || 0; });

              window.sidequestTrendChartInstance = new Chart(ctx, {
                type: 'line',
                data: {
                  labels: labels,
                  datasets: [
                    {
                      label: 'Entries Submitted',
                      data: submitted,
                      borderColor: '#3b82f6',
                      backgroundColor: 'rgba(59, 130, 246, 0.16)',
                      fill: true,
                      tension: 0.35,
                      pointRadius: 3,
                      pointHoverRadius: 4
                    },
                    {
                      label: 'Approved',
                      data: approved,
                      borderColor: '#10b981',
                      backgroundColor: 'rgba(16, 185, 129, 0.12)',
                      fill: true,
                      tension: 0.35,
                      pointRadius: 3,
                      pointHoverRadius: 4
                    },
                    {
                      label: 'Projects Shipped',
                      data: shippedProjects,
                      borderColor: '#f1802d',
                      backgroundColor: 'rgba(241, 128, 45, 0.08)',
                      fill: false,
                      borderDash: [6, 4],
                      tension: 0.3,
                      pointRadius: 3,
                      pointHoverRadius: 4
                    }
                  ]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  interaction: {
                    mode: 'index',
                    intersect: false
                  },
                  plugins: {
                    legend: {
                      display: true,
                      position: 'bottom'
                    },
                    tooltip: {
                      callbacks: {
                        label: function(context) {
                          return context.dataset.label + ': ' + context.raw;
                        }
                      }
                    }
                  },
                  scales: {
                    y: {
                      beginAtZero: true,
                      ticks: { precision: 0 },
                      title: { display: true, text: 'Projects / Entries' }
                    }
                  }
                }
              });
            });
          });
        </script>
      <% else %>
        <p class="fraud-stats-error">No sidequest trend data available.</p>
      <% end %>
    </div>
  </div>
</div>
