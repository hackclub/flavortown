<div class="super-mega-dashboard__dashboard">
  <div class="super-mega-dashboard__header super-mega-dashboard__header--pyramid-scheme">
    <h2>Pyramid Scheme</h2>
  </div>

  <% if @pyramid_scheme_stats[:error].present? %>
    <div class="super-mega-dashboard__cards super-mega-dashboard__cards--analytics">
      <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
        <h3>Pyramid feed unavailable</h3>
        <p class="fraud-stats-error"><%= @pyramid_scheme_stats[:error] %></p>
      </div>
    </div>
  <% else %>
    <% if @pyramid_scheme_stats[:partial_data] %>
      <div class="super-mega-dashboard__cards super-mega-dashboard__cards--analytics">
        <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
          <h3>Partial Pyramid data</h3>
          <p class="fraud-stats-error">Unavailable Pyramid API fields are shown as 0.</p>
        </div>
      </div>
    <% end %>

    <% hours_prev = @pyramid_scheme_stats[:verified_hours_previous_week] %>
    <% hours_curr = @pyramid_scheme_stats[:verified_hours_last_week] %>
    <% hours_delta = hours_curr - hours_prev %>
    <% refs_prev = @pyramid_scheme_stats[:referrals_gained_previous_week] %>
    <% refs_curr = @pyramid_scheme_stats[:referrals_gained_last_week] %>
    <% refs_delta = refs_curr - refs_prev %>
    <div class="super-mega-dashboard__card super-mega-dashboard__card--total-numbers">
      <h3>Total Numbers</h3>
      <div class="super-mega-dashboard__total-numbers-grid">
        <div class="super-mega-dashboard__total-numbers-metric">
          <span class="super-mega-dashboard__total-numbers-value orange"><%= number_with_precision(@pyramid_scheme_stats[:total_hours_logged], precision: 1, strip_insignificant_zeros: true) %></span>
          <span class="super-mega-dashboard__total-numbers-label">Verified Hours</span>
          <span class="super-mega-dashboard__total-numbers-delta">
            <span class="<%= hours_delta >= 0 ? "green" : "red" %>"><%= hours_delta >= 0 ? "+" : "" %><%= number_with_precision(hours_delta, precision: 1, strip_insignificant_zeros: true) %>h last 7d</span>
            <span class="super-mega-dashboard__total-numbers-range">(<%= number_with_precision(hours_prev, precision: 1, strip_insignificant_zeros: true) %> &rarr; <%= number_with_precision(hours_curr, precision: 1, strip_insignificant_zeros: true) %>)</span>
          </span>
        </div>
        <div class="super-mega-dashboard__total-numbers-metric">
          <span class="super-mega-dashboard__total-numbers-value blue"><%= number_with_delimiter(@pyramid_scheme_stats[:total_referrals_verified]) %></span>
          <span class="super-mega-dashboard__total-numbers-label">Verified Referrals</span>
          <span class="super-mega-dashboard__total-numbers-delta">
            <span class="<%= refs_delta >= 0 ? "green" : "red" %>"><%= refs_delta >= 0 ? "+" : "" %><%= refs_delta %> last 7d</span>
            <span class="super-mega-dashboard__total-numbers-range">(<%= number_with_delimiter(refs_prev) %> &rarr; <%= number_with_delimiter(refs_curr) %>)</span>
          </span>
        </div>
        <div class="super-mega-dashboard__total-numbers-metric">
          <span class="super-mega-dashboard__total-numbers-value purple"><%= number_with_delimiter(@pyramid_scheme_stats[:shipped_projects]) %></span>
          <span class="super-mega-dashboard__total-numbers-label">Projects Shipped</span>
        </div>
        <div class="super-mega-dashboard__total-numbers-metric">
          <span class="super-mega-dashboard__total-numbers-value green"><%= number_with_delimiter(@pyramid_scheme_stats[:total_users]) %></span>
          <span class="super-mega-dashboard__total-numbers-label">All Users (<%= @pyramid_scheme_stats[:flavortime_users] %> also on Flavortime)</span>
        </div>
      </div>
    </div>

    <div class="super-mega-dashboard__cards super-mega-dashboard__cards--analytics">
      <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
        <div class="super-mega-dashboard__card-toolbar">
          <h3>Weekly Growth & Verified Hours</h3>
          <label class="super-mega-dashboard__range-control" for="pyramidActivityRange">
            <span>Range</span>
            <select id="pyramidActivityRange">
              <option value="1w">Last week</option>
              <option value="4w">Last 4 weeks</option>
              <option value="8w" selected>Last 8 weeks</option>
              <option value="12w">Last 12 weeks</option>
              <option value="all">All time</option>
            </select>
          </label>
        </div>
        <div class="super-mega-dashboard__chart-shell">
          <canvas id="pyramidActivityChart"></canvas>
        </div>
      </div>

      <div class="super-mega-dashboard__card super-mega-dashboard__card--half">
        <h3>Referral Flow</h3>
        <div class="super-mega-dashboard__chart-shell">
          <canvas id="pyramidReferralChart"></canvas>
        </div>
      </div>

      <div class="super-mega-dashboard__card super-mega-dashboard__card--half">
        <h3>Poster Outcomes</h3>
        <div class="super-mega-dashboard__chart-shell super-mega-dashboard__chart-shell--pie">
          <canvas id="pyramidPosterChart"></canvas>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% unless @pyramid_scheme_stats[:error].present? %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const activityCtx = document.getElementById('pyramidActivityChart');
      const rangeSelect = document.getElementById('pyramidActivityRange');
      const referralCtx = document.getElementById('pyramidReferralChart');
      const posterCtx = document.getElementById('pyramidPosterChart');
      if (!activityCtx || !rangeSelect || !referralCtx || !posterCtx || typeof Chart === 'undefined') return;

      const activityTimeline = <%= raw @pyramid_scheme_stats[:activity_timeline].to_json %>;
      const referralData = <%= raw @pyramid_scheme_stats[:referral_chart].to_json %>;
      const posterData = <%= raw @pyramid_scheme_stats[:poster_chart].to_json %>;
      const formatDate = (value) => new Date(value).toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      const formatWeekLabel = (value) => `Week of ${formatDate(value)}`;
      const startOfWeek = (value) => {
        const date = new Date(value);
        const day = date.getDay();
        const offset = (day + 6) % 7;
        date.setDate(date.getDate() - offset);
        date.setHours(0, 0, 0, 0);
        return date;
      };

      const sliceTimeline = (timeline) => {
        if (rangeSelect.value === 'all') return timeline;

        const now = new Date();
        const cutoffByRange = {
          '1w': new Date(now.getTime() - (7 * 24 * 60 * 60 * 1000)),
          '4w': new Date(now.getTime() - (28 * 24 * 60 * 60 * 1000)),
          '8w': new Date(now.getTime() - (56 * 24 * 60 * 60 * 1000)),
          '12w': new Date(now.getTime() - (84 * 24 * 60 * 60 * 1000))
        };
        const cutoff = cutoffByRange[rangeSelect.value];
        if (!cutoff) return timeline;

        return timeline.filter((entry) => new Date(entry.date) >= cutoff);
      };

      const bucketTimelineByWeek = (timeline) => {
        const buckets = new Map();

        timeline.forEach((entry) => {
          const weekStart = startOfWeek(entry.date).toISOString();
          if (!buckets.has(weekStart)) {
            buckets.set(weekStart, {
              date: weekStart,
              users_added: 0,
              referrals_completed: 0,
              verified_hours: 0,
              posters_approved: 0
            });
          }

          const bucket = buckets.get(weekStart);
          bucket.users_added += entry.users_added || 0;
          bucket.referrals_completed += entry.referrals_completed || 0;
          bucket.verified_hours += entry.verified_hours || 0;
          bucket.posters_approved += entry.posters_approved || 0;
        });

        return Array.from(buckets.values()).sort((left, right) => new Date(left.date) - new Date(right.date));
      };

      const buildActivityChartData = (timeline) => {
        const weeklyTimeline = bucketTimelineByWeek(timeline);

        return {
          labels: weeklyTimeline.map((entry) => formatWeekLabel(entry.date)),
          datasets: [{
            type: 'bar',
            label: 'Users Added',
            data: weeklyTimeline.map((entry) => entry.users_added),
            backgroundColor: 'rgba(59, 130, 246, 0.78)',
            borderColor: '#2563eb',
            borderWidth: 1,
            borderRadius: 10,
            maxBarThickness: 34,
            yAxisID: 'y'
          }, {
            type: 'bar',
            label: 'Completed Referrals',
            data: weeklyTimeline.map((entry) => entry.referrals_completed),
            backgroundColor: 'rgba(16, 185, 129, 0.68)',
            borderColor: '#059669',
            borderWidth: 1,
            borderRadius: 10,
            maxBarThickness: 34,
            yAxisID: 'y'
          }, {
            type: 'line',
            label: 'Verified Hours',
            data: weeklyTimeline.map((entry) => Number(entry.verified_hours.toFixed(1))),
            borderColor: '#f59e0b',
            backgroundColor: 'rgba(245, 158, 11, 0.16)',
            borderWidth: 3,
            pointRadius: 3,
            pointHoverRadius: 5,
            tension: 0.28,
            fill: true,
            yAxisID: 'y1'
          }]
        };
      };

      const activityChart = new Chart(activityCtx, {
        data: buildActivityChartData(sliceTimeline(activityTimeline)),
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false
          },
          plugins: {
            legend: {
              position: 'bottom'
            },
            tooltip: {
              callbacks: {
                label(context) {
                  if (context.dataset.label === 'Verified Hours') {
                    return `${context.dataset.label}: ${context.parsed.y}h`;
                  }

                  return `${context.dataset.label}: ${context.parsed.y}`;
                }
              }
            }
          },
          scales: {
            x: {
              ticks: {
                font: { size: 11 },
                autoSkip: true,
                maxTicksLimit: 10,
                maxRotation: 0
              }
            },
            y: {
              beginAtZero: true,
              ticks: {
                precision: 0
              },
              title: {
                display: true,
                text: 'Users / referrals'
              }
            },
            y1: {
              beginAtZero: true,
              position: 'right',
              grid: {
                drawOnChartArea: false
              },
              title: {
                display: true,
                text: 'Verified hours'
              }
            }
          }
        }
      });

      const updateActivityChart = function() {
        const nextData = buildActivityChartData(sliceTimeline(activityTimeline));
        activityChart.data.labels = nextData.labels;
        activityChart.data.datasets = nextData.datasets;
        activityChart.update();
      };

      rangeSelect.addEventListener('change', updateActivityChart);
      updateActivityChart();

      new Chart(referralCtx, {
        type: 'bar',
        data: {
          labels: referralData.labels,
          datasets: [{
            data: referralData.values,
            backgroundColor: ['#f59e0b', '#3b82f6', '#10b981'],
            borderRadius: 10
          }]
        },
        plugins: [ChartDataLabels],
        options: {
          indexAxis: 'y',
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: { display: false },
            datalabels: {
              anchor: 'end',
              align: 'end',
              color: '#e2e8f0',
              font: { weight: 'bold', size: 13 },
              formatter: (value) => value.toLocaleString()
            }
          },
          scales: {
            x: {
              beginAtZero: true
            }
          }
        }
      });

      new Chart(posterCtx, {
        type: 'doughnut',
        data: {
          labels: posterData.labels,
          datasets: [{
            data: posterData.values,
            backgroundColor: ['#10b981', '#8b5cf6', '#ef4444']
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom'
            }
          }
        }
      });
    });
  </script>
<% end %>
