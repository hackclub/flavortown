<div class="super-mega-dashboard__dashboard">
  <div class="super-mega-dashboard__header super-mega-dashboard__header--primary">
    <h2>Super Mega Funnel</h2>
    <p class="super-mega-dashboard__subtitle">User journey from start_flow to devlog_created</p>
  </div>

  <% if @funnel_steps.blank? %>
    <div class="super-mega-dashboard__empty-state">
      <p class="super-mega-dashboard__empty-title">No funnel data available</p>
    </div>
  <% else %>
    <div class="d3-funnel-container">
      <div id="d3FunnelChart"></div>
      <div id="funnelDebug" class="d3-funnel-debug">
        Loaded <%= @funnel_steps.length %> funnel steps
      </div>
      <div id="funnelTooltip" class="d3-funnel-tooltip" aria-hidden="true"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/d3@7"></script>
    <script>
      (function renderSignupFunnel() {
        try {
          const funnelStepsData = <%= raw @funnel_steps.to_json %>;

          if (!funnelStepsData || funnelStepsData.length === 0) {
            console.warn("[Funnel] No data available");
            return;
          }

          const data = funnelStepsData.map((step) => {
            const rawName = String(step.name || "");

            return {
              key: rawName,
              value: parseInt(step.count, 10) || 0,
            };
          });

          if (!data.some((d) => d.value > 0)) {
            console.error("[Funnel] All values are zero");
            return;
          }

          const container = document.querySelector("#d3FunnelChart");
          let tooltip = document.getElementById("funnelTooltip");
          if (!container) {
            console.error("[Funnel] Container not found");
            return;
          }

          if (tooltip && tooltip.parentElement !== document.body) {
            document.body.appendChild(tooltip);
          }

          const containerWidth = container.clientWidth || 960;
          const margin = { top: 32, right: 16, bottom: 24, left: 16 };
          const height = 420;

          const baseInnerWidth = containerWidth - margin.left - margin.right;
          const innerHeight = height - margin.top - margin.bottom;
          const centerY = innerHeight / 2;

          const maxValue = d3.max(data, (d) => d.value) || 1;
          const maxBandHeight = innerHeight * 0.9;

          const minChartInnerWidth = 540;
          const minStepWidth = 150; 
          let chartInnerWidth = Math.max(baseInnerWidth, minChartInnerWidth);
          const stepCount = Math.max(data.length, 1);
          let stepWidth = chartInnerWidth / stepCount;

          if (stepWidth < minStepWidth) {
            stepWidth = minStepWidth;
            chartInnerWidth = stepWidth * stepCount;
          }
          const bandWidth = stepWidth;
          const width = chartInnerWidth + margin.left + margin.right;
          const innerWidth = width - margin.left - margin.right;
          const points = data.map((d, index) => {
            const heightForStep = maxBandHeight * (d.value / maxValue);
            const centerX = (index + 0.5) * bandWidth;
            return {
              ...d,
              x: centerX,
              bandHeight: heightForStep,
            };
          });

          const topPoints = [];
          const bottomPoints = [];

          if (points.length > 0) {
            const boundaryHeights = [];
            for (let i = 0; i <= points.length; i += 1) {
              let bandHeight = 0;
              if (i === 0) {
                bandHeight = points[0].bandHeight;
              } else if (i === points.length) {
                bandHeight = points[points.length - 1].bandHeight;
              } else {
                bandHeight = (points[i - 1].bandHeight + points[i].bandHeight) / 2;
              }
              boundaryHeights.push(bandHeight);
            }

            for (let i = 0; i <= stepCount; i += 1) {
              const x = i * bandWidth;
              const bandHeight = boundaryHeights[i];
              topPoints.push([x, centerY - bandHeight / 2]);
            }
            for (let i = stepCount; i >= 0; i -= 1) {
              const x = i * bandWidth;
              const bandHeight = boundaryHeights[i];
              bottomPoints.push([x, centerY + bandHeight / 2]);
            }
          }

          const allPoints = topPoints.concat(bottomPoints);

          const buildLinearPath = (pts) => {
            if (!pts.length) return "";
            const [first, ...rest] = pts;
            const moveTo = `M${first[0]},${first[1]}`;
            const lineTos = rest.map((d) => `L${d[0]},${d[1]}`).join(" ");
            return `${moveTo} ${lineTos} Z`;
          };

          const pathData = buildLinearPath(allPoints);
          const svg = d3
            .create("svg")
            .attr("viewBox", `0 0 ${width} ${height}`)
            .attr("width", width)
            .attr("height", height)
            .attr("preserveAspectRatio", "xMidYMid meet");

          const defs = svg.append("defs");
          const gradient = defs
            .append("linearGradient")
            .attr("id", "funnelGradient")
            .attr("x1", "0%")
            .attr("y1", "0%")
            .attr("x2", "100%")
            .attr("y2", "0%");

          gradient.append("stop").attr("offset", "0%").attr("stop-color", "#4c6fff");
          gradient.append("stop").attr("offset", "100%").attr("stop-color", "#93c5fd");

          const g = svg
            .append("g")
            .attr("transform", `translate(${margin.left},${margin.top})`);

          g.append("path")
            .attr("d", pathData)
            .attr("fill", "url(#funnelGradient)")
            .attr("fill-opacity", 0.9);

          g.append("path")
            .attr("d", pathData)
            .attr("fill", "none")
            .attr("stroke", "var(--color-brown-700)")
            .attr("stroke-width", 1)
            .attr("stroke-opacity", 0.9);

          const separatorGroup = g.append("g");
          const sectionTop = centerY - maxBandHeight / 2 - 16;
          const sectionBottom = centerY + maxBandHeight / 2 + 16;
          for (let i = 0; i <= stepCount; i += 1) {
            const x = i * bandWidth;
            separatorGroup
              .append("line")
              .attr("x1", x)
              .attr("y1", sectionTop)
              .attr("x2", x)
              .attr("y2", sectionBottom)
              .attr("stroke", "var(--color-brown-500)")
              .attr("stroke-width", 1)
              .attr("stroke-opacity", 0.9);
          }

          const overlay = g.append("g");
          const firstValue = data[0].value || 0;
          const formatPercent = (value) => `${(value * 100).toFixed(1)}%`;
          const formatDelta = (value) => {
            const sign = value > 0 ? "+" : "";
            return `${sign}${(value * 100).toFixed(1)}%`;
          };

          points.forEach((point, index) => {
            const currentValue = point.value;
            const prevValue = index === 0 ? currentValue : points[index - 1].value || currentValue;
            const retentionFromPrevious = index === 0 ? 1 : prevValue === 0 ? 0 : currentValue / prevValue;
            const changeVsPrevious = index === 0 ? 0 : prevValue === 0 ? 0 : (currentValue - prevValue) / prevValue;

            const bandLeft = index * bandWidth;
            const bandCenter = bandLeft + bandWidth / 2;

            overlay
              .append("rect")
              .attr("x", bandLeft)
              .attr("y", centerY - maxBandHeight / 2 - 16)
              .attr("width", bandWidth)
              .attr("height", maxBandHeight + 32)
              .attr("fill", "transparent")
              .on("mousemove", (event) => {
                if (!tooltip) return;

                const retainedFromFirst = firstValue === 0 ? 0 : currentValue / firstValue;

                tooltip.innerHTML = `
                  <div class="d3-funnel-tooltip__step">Step: <span>${point.key}</span></div>
                  <div class="d3-funnel-tooltip__count">Count: ${currentValue.toLocaleString()}</div>
                  <hr />
                  <div class="d3-funnel-tooltip__row">
                    <span>Retained</span>
                    <span>${formatPercent(retentionFromPrevious)}</span>
                  </div>
                  <div class="d3-funnel-tooltip__row">
                    <span>Compared to previous</span>
                    <span>${index === 0 ? "—" : formatDelta(changeVsPrevious)}</span>
                  </div>
                  <div class="d3-funnel-tooltip__row d3-funnel-tooltip__row--muted">
                    <span>From first step</span>
                    <span>${formatPercent(retainedFromFirst)}</span>
                  </div>
                `;
                tooltip.style.display = "block";
                tooltip.style.opacity = "1";
                tooltip.setAttribute("aria-hidden", "false");

                const viewportWidth = window.innerWidth || document.documentElement.clientWidth;
                const viewportHeight = window.innerHeight || document.documentElement.clientHeight;
                const padding = 16;

                const rect = tooltip.getBoundingClientRect();

                let left = event.clientX + padding;
                let top = event.clientY - rect.height / 2;

                if (left + rect.width + padding > viewportWidth) {
                  left = event.clientX - rect.width - padding;
                }

                if (top < padding) {
                  top = padding;
                } else if (top + rect.height + padding > viewportHeight) {
                  top = viewportHeight - rect.height - padding;
                }

                tooltip.style.left = `${left + window.scrollX}px`;
                tooltip.style.top = `${top + window.scrollY}px`;
              })
              .on("mouseleave", () => {
                if (!tooltip) return;
                tooltip.style.display = "none";
                tooltip.style.opacity = "0";
                tooltip.setAttribute("aria-hidden", "true");
              });

            g
              .append("text")
              .attr("class", "d3-funnel-label d3-funnel-label--step")
              .attr("x", bandCenter)
              .attr("y", centerY - maxBandHeight / 2 - 12)
              .attr("text-anchor", "middle")
              .text(point.key);

            g
              .append("text")
              .attr("class", "d3-funnel-label d3-funnel-label--metric")
              .attr("x", bandCenter)
              .attr("y", centerY + maxBandHeight / 2 + 20)
              .attr("text-anchor", "middle")
              .text(`${currentValue.toLocaleString()} · ${formatPercent(firstValue === 0 ? 0 : currentValue / firstValue)}`);
          });

          const leftLabelGroup = svg
            .append("g")
            .attr("transform", `translate(24,${margin.top + centerY})`);

          leftLabelGroup
            .append("text")
            .attr("class", "d3-funnel-total-label")
            .attr("x", 0)
            .attr("y", -6)
            .text(firstValue.toLocaleString());

          leftLabelGroup
            .append("text")
            .attr("class", "d3-funnel-total-subtitle")
            .attr("x", 0)
            .attr("y", 14)
            .text("Count");

          container.innerHTML = "";
          container.appendChild(svg.node());
        } catch (error) {
          console.error("[Funnel] Chart rendering failed:", error);
          const funnelDebug = document.getElementById("funnelDebug");
          if (funnelDebug) {
            funnelDebug.innerHTML = `rendering failed: ${error.message}`;
            funnelDebug.style.display = "block";
            funnelDebug.style.color = "#d00";
          }
        }
      })();
    </script>
  <% end %>
</div>
