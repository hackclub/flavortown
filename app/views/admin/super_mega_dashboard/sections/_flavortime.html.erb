<div class="super-mega-dashboard__dashboard">
  <div class="super-mega-dashboard__header super-mega-dashboard__header--flavortime">
    <h2>Flavortime</h2>
    <%= link_to "View Full Dashboard →", admin_flavortime_dashboard_path, class: "super-mega-link" %>
  </div>

  <% if @flavortime_summary[:error].present? %>
    <div class="super-mega-dashboard__cards super-mega-dashboard__cards--analytics">
      <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
        <h3>Flavortime feed unavailable</h3>
        <p class="fraud-stats-error"><%= @flavortime_summary[:error] %></p>
      </div>
    </div>
  <% else %>
    <div class="super-mega-dashboard__stats super-mega-dashboard__stats--dashboard">
      <div class="super-mega-dashboard__stat">
        <span class="super-mega-dashboard__stat--value green"><%= @flavortime_summary[:active_users] %></span>
        <span class="super-mega-dashboard__stat--label">Active Now</span>
      </div>
      <div class="super-mega-dashboard__stat">
        <span class="super-mega-dashboard__stat--value blue"><%= @flavortime_summary[:total_users] %></span>
        <span class="super-mega-dashboard__stat--label">All-Time Users</span>
      </div>
      <div class="super-mega-dashboard__stat">
        <span class="super-mega-dashboard__stat--value red"><%= number_with_delimiter(@flavortime_summary[:total_sessions]) %></span>
        <span class="super-mega-dashboard__stat--label">Recorded Sessions</span>
      </div>
      <div class="super-mega-dashboard__stat">
        <span class="super-mega-dashboard__stat--value yellow"><%= number_with_precision(@flavortime_summary[:status_hours], precision: 1, strip_insignificant_zeros: true) %></span>
        <span class="super-mega-dashboard__stat--label">Status Hours</span>
      </div>
    </div>

    <div class="super-mega-dashboard__cards super-mega-dashboard__cards--analytics">
      <div class="super-mega-dashboard__card super-mega-dashboard__card--full">
        <h3>Activity Trend</h3>
        <div class="super-mega-dashboard__chart-shell">
          <canvas id="flavortimeActivityChart"></canvas>
        </div>
      </div>

      <div class="super-mega-dashboard__card super-mega-dashboard__card--half">
        <h3>Sessions by Platform</h3>
        <div class="super-mega-dashboard__chart-shell super-mega-dashboard__chart-shell--pie">
          <canvas id="flavortimePlatformChart"></canvas>
        </div>
      </div>

      <div class="super-mega-dashboard__card super-mega-dashboard__card--half">
        <h3>Sessions by Version</h3>
        <div class="super-mega-dashboard__chart-shell super-mega-dashboard__chart-shell--pie">
          <canvas id="flavortimeVersionChart"></canvas>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% unless @flavortime_summary[:error].present? %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const activityCtx = document.getElementById('flavortimeActivityChart');
      const platformCtx = document.getElementById('flavortimePlatformChart');
      const versionCtx = document.getElementById('flavortimeVersionChart');
      if (!activityCtx || !platformCtx || !versionCtx || typeof Chart === 'undefined') return;

      const activityData = <%= raw @flavortime_summary[:activity_chart].to_json %>;
      const platformData = <%= raw @flavortime_summary[:sessions_by_platform].to_json %>;
      const versionData = <%= raw @flavortime_summary[:sessions_by_version].to_json %>;
      const piePalette = ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444', '#14b8a6'];

      new Chart(activityCtx, {
        data: {
          labels: activityData.labels,
          datasets: [{
            type: 'bar',
            label: 'Sessions',
            data: activityData.sessions,
            backgroundColor: 'rgba(59, 130, 246, 0.75)',
            borderRadius: 8,
            yAxisID: 'y'
          }, {
            type: 'line',
            label: 'Status Hours',
            data: activityData.status_hours,
            borderColor: '#f59e0b',
            backgroundColor: 'rgba(245, 158, 11, 0.2)',
            tension: 0.35,
            fill: false,
            yAxisID: 'y1'
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: {
            mode: 'index',
            intersect: false
          },
          plugins: {
            legend: {
              position: 'bottom'
            }
          },
          scales: {
            x: {
              ticks: { font: { size: 11 } }
            },
            y: {
              beginAtZero: true,
              title: {
                display: true,
                text: 'Sessions'
              }
            },
            y1: {
              beginAtZero: true,
              position: 'right',
              grid: {
                drawOnChartArea: false
              },
              title: {
                display: true,
                text: 'Status Hours'
              }
            },
          }
        }
      });

      new Chart(platformCtx, {
        type: 'pie',
        data: {
          labels: Object.keys(platformData),
          datasets: [{
            data: Object.values(platformData),
            backgroundColor: piePalette
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom'
            }
          }
        }
      });

      new Chart(versionCtx, {
        type: 'pie',
        data: {
          labels: Object.keys(versionData),
          datasets: [{
            data: Object.values(versionData),
            backgroundColor: piePalette
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            legend: {
              position: 'bottom'
            }
          }
        }
      });
    });
  </script>
<% end %>
