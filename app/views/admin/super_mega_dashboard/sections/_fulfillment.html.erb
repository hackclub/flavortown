    <div class="super-mega-dashboard__dashboard">
      <div class="super-mega-dashboard__header super-mega-dashboard__header--fulfillment">
        <h2>Fulfillment Overview</h2>
        <%= link_to "View Full Dashboard →", admin_fulfillment_dashboard_index_path, class: "super-mega-link" %>
      </div>

      <div class="super-mega-dashboard__cards super-mega-dashboard__cards--fulfillment">
        <div class="fulfillment-stats-row">
          <%
            card_color = ->(key, awaiting_count) {
              return nil unless awaiting_count.is_a?(Integer)
              case key
              when :hq_mail, :other
                if awaiting_count >= 10 then "red"
                elsif awaiting_count >= 5 then "amber"
                else "green"
                end
              when :third_party
                if awaiting_count > 40 then "red"
                elsif awaiting_count >= 20 then "amber"
                else "green"
                end
              when :warehouse
                @fulfillment[:warehouse_has_stale] ? "red" : "green"
              end
            }
          %>
          <% [
            [:all, "All"],
            [:hq_mail, "HQ Stuff"],
            [:third_party, "Amber & Co"],
            [:warehouse, "Warehouse"],
            [:other, "Other"]
          ].each do |key, label| %>
            <% color = card_color.call(key, @fulfillment[key][:awaiting]) %>
            <div class="fulfillment-stats-row__card <%= "fulfillment-stats-row__card--#{color}" if color %>">
              <h4 class="fulfillment-stats-row__title"><%= label %></h4>
              <div class="fulfillment-stats-row__numbers">
                <span class="fulfillment-stats-row__num yellow"><%= @fulfillment[key][:awaiting] %> <small>Awaiting</small></span>
                <span class="fulfillment-stats-row__num green"><%= @fulfillment[key][:fulfilled] %> <small>Fulfilled</small></span>
              </div>
            </div>
          <% end %>
        </div>

        <div class="super-mega-dashboard__card super-mega-dashboard__card--fulfillment-graph">
          <h3>Fulfilment Trend (30d)</h3>
          <% if @fulfillment_trend_data.present? %>
            <div class="d3-fulfillment-trend-container" id="fulfillmentTrendContainer">
              <div class="d3-stream-tooltip" id="fulfillmentTrendTooltip"></div>
            </div>
            <div class="d3-stream-legend" id="fulfillmentTrendLegend"></div>
            <script>
              document.addEventListener('DOMContentLoaded', function() {
                ensureD3(function() {
                  var raw = <%= raw @fulfillment_trend_data.to_json %>;
                  var sortedDates = Object.keys(raw).sort();
                  var tableData = sortedDates.map(function(d) {
                    return {
                      date: new Date(d),
                      dateStr: d,
                      fulfilled: raw[d].fulfilled || 0,
                      created: raw[d].created || 0
                    };
                  });

                  var seriesConfig = [
                    { key: 'fulfilled', label: 'Fulfilled', color: '#10b981', fillColor: 'rgba(16, 185, 129, 0.15)' },
                    { key: 'created',   label: 'New Orders', color: '#3b82f6', fillColor: 'rgba(59, 130, 246, 0.08)' }
                  ];

                  var container = document.getElementById('fulfillmentTrendContainer');
                  var tooltip  = document.getElementById('fulfillmentTrendTooltip');
                  var legendEl = document.getElementById('fulfillmentTrendLegend');
                  var margin = { top: 12, right: 12, bottom: 24, left: 36 };
                  var height = 220;

                  var completedData = tableData.slice(0, -1);
                  var lastTwo = tableData.length >= 2 ? tableData.slice(-2) : tableData;

                  function render() {
                    container.querySelectorAll('svg').forEach(function(el) { el.remove(); });
                    var width = container.clientWidth;
                    var innerW = width - margin.left - margin.right;
                    var innerH = height - margin.top - margin.bottom;

                    var svg = d3.select(container).append('svg')
                      .attr('width', width).attr('height', height);
                    var g = svg.append('g')
                      .attr('transform', 'translate(' + margin.left + ',' + margin.top + ')');

                    var x = d3.scaleTime()
                      .domain(d3.extent(tableData, function(d) { return d.date; }))
                      .range([0, innerW]);

                    var yMax = d3.max(tableData, function(d) {
                      return Math.max(d.fulfilled, d.created);
                    }) || 1;

                    var y = d3.scaleLinear()
                      .domain([0, yMax * 1.1])
                      .range([innerH, 0]);

                    g.append('g')
                      .attr('class', 'd3-stream-grid')
                      .call(d3.axisLeft(y).ticks(4).tickSize(-innerW).tickFormat(d3.format('d')))
                      .selectAll('text').style('font-size', '7px');

                    g.append('g')
                      .attr('transform', 'translate(0,' + innerH + ')')
                      .call(d3.axisBottom(x).ticks(Math.min(sortedDates.length, 8)).tickFormat(d3.timeFormat('%b %d')))
                      .selectAll('text').style('font-size', '7px');

                    var areaGen = d3.area()
                      .x(function(d) { return x(d.date); })
                      .y0(innerH);

                    var lineGen = d3.line()
                      .x(function(d) { return x(d.date); });

                    if (completedData.length > 0) {
                      g.append('path')
                        .datum(completedData)
                        .attr('fill', seriesConfig[0].fillColor)
                        .attr('d', areaGen.y1(function(d) { return y(d.fulfilled); }));
                    }

                    seriesConfig.forEach(function(cfg) {
                      if (completedData.length > 0) {
                        g.append('path')
                          .datum(completedData)
                          .attr('fill', 'none')
                          .attr('stroke', cfg.color)
                          .attr('stroke-width', 1.5)
                          .attr('d', lineGen.y(function(d) { return y(d[cfg.key]); }));
                      }
                    });

                    if (lastTwo.length === 2) {
                      seriesConfig.forEach(function(cfg) {
                        g.append('path')
                          .datum(lastTwo)
                          .attr('fill', 'none')
                          .attr('stroke', cfg.color)
                          .attr('stroke-width', 1.5)
                          .attr('stroke-dasharray', '4,3')
                          .attr('d', lineGen.y(function(d) { return y(d[cfg.key]); }));
                      });
                    }

                    seriesConfig.forEach(function(cfg) {
                      g.selectAll('.dot-' + cfg.key)
                        .data(completedData)
                        .join('circle')
                        .attr('cx', function(d) { return x(d.date); })
                        .attr('cy', function(d) { return y(d[cfg.key]); })
                        .attr('r', 2.5)
                        .attr('fill', cfg.color)
                        .attr('stroke', '#fff')
                        .attr('stroke-width', 1);
                    });

                    var lastPoint = tableData[tableData.length - 1];
                    seriesConfig.forEach(function(cfg) {
                      g.append('circle')
                        .attr('cx', x(lastPoint.date))
                        .attr('cy', y(lastPoint[cfg.key]))
                        .attr('r', 3)
                        .attr('fill', '#fff')
                        .attr('stroke', cfg.color)
                        .attr('stroke-width', 1.5)
                        .attr('stroke-dasharray', '2,2');
                    });

                    var crosshair = g.append('line')
                      .attr('y1', 0).attr('y2', innerH)
                      .attr('stroke', '#94a3b8')
                      .attr('stroke-width', 1)
                      .attr('stroke-dasharray', '3,3')
                      .style('opacity', 0)
                      .style('pointer-events', 'none');

                    g.append('rect')
                      .attr('width', innerW).attr('height', innerH)
                      .attr('fill', 'transparent')
                      .on('mousemove', function(event) {
                        var pointer = d3.pointer(event, g.node());
                        var xPos = pointer[0];
                        var hoveredDate = x.invert(xPos);
                        var idx = d3.bisectCenter(tableData.map(function(r) { return r.date; }), hoveredDate);
                        var d = tableData[idx];
                        var isToday = idx === tableData.length - 1;
                        var dateStr = d.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });

                        crosshair
                          .attr('x1', x(d.date)).attr('x2', x(d.date))
                          .style('opacity', 1);

                        tooltip.innerHTML = '<strong>' + dateStr + (isToday ? ' (in progress)' : '') + '</strong><br>'
                          + '<span style="color:#10b981">●</span> Fulfilled: ' + d.fulfilled + '<br>'
                          + '<span style="color:#3b82f6">●</span> New Orders: ' + d.created;

                        var containerPointer = d3.pointer(event, container);
                        var tooltipLeft = containerPointer[0] + 14;
                        var tooltipTop = containerPointer[1] - 10;

                        if (tooltipLeft + 140 > width) {
                          tooltipLeft = containerPointer[0] - 150;
                        }

                        tooltip.style.left = tooltipLeft + 'px';
                        tooltip.style.top  = tooltipTop + 'px';
                        tooltip.classList.add('is-visible');
                      })
                      .on('mouseleave', function() {
                        crosshair.style('opacity', 0);
                        tooltip.classList.remove('is-visible');
                      });
                  }

                  seriesConfig.forEach(function(cfg) {
                    var span = document.createElement('span');
                    span.innerHTML = '<span class="d3-stream-legend__swatch" style="background:' + cfg.color + '"></span>' + cfg.label;
                    legendEl.appendChild(span);
                  });

                  render();
                  window.addEventListener('resize', render);
                });
              });
            </script>
          <% else %>
            <p class="fraud-stats-error">No trend data available</p>
          <% end %>
        </div>

        <div class="super-mega-dashboard__card super-mega-dashboard__card--fulfillment-graph">
          <h3>Order States (30d)</h3>
          <% if @order_states_trend_data.present? %>
            <div id="orderStatesStream" class="d3-stream-container">
              <div class="d3-stream-tooltip" id="orderStatesTooltip"></div>
            </div>
            <div class="d3-stream-legend" id="orderStatesLegend"></div>
            <script>
              function ensureD3(cb) {
                if (typeof d3 !== 'undefined') { cb(); return; }
                var s = document.createElement('script');
                s.src = 'https://cdn.jsdelivr.net/npm/d3@7';
                s.onload = cb;
                document.head.appendChild(s);
              }

              document.addEventListener('DOMContentLoaded', function() {
                ensureD3(function() {
                  var raw = <%= raw @order_states_trend_data.to_json %>;
                  var stateConfig = {
                    'pending':                         { label: 'Pending',            color: '#ef4444' },
                    'awaiting_periodical_fulfillment': { label: 'Awaiting Fulfilment', color: '#f59e0b' },
                    'on_hold':                         { label: 'On Hold',            color: '#6366f1' },
                    'closed':                          { label: 'Closed (Fulfilled / Rejected / Refunded)', color: '#10b981' }
                  };

                  var sortedDates = Object.keys(raw).sort();
                  var keys = Object.keys(raw[sortedDates[0]] || {});
                  var tableData = sortedDates.map(function(d) {
                    var row = { date: new Date(d) };
                    keys.forEach(function(k) { row[k] = raw[d][k] || 0; });
                    return row;
                  });

                  var container = document.getElementById('orderStatesStream');
                  var tooltip  = document.getElementById('orderStatesTooltip');
                  var legendEl = document.getElementById('orderStatesLegend');
                  var margin = { top: 10, right: 10, bottom: 20, left: 36 };
                  var height = 220;

                  function render() {
                    container.querySelectorAll('svg').forEach(function(el) { el.remove(); });
                    var width = container.clientWidth;
                    var innerW = width - margin.left - margin.right;
                    var innerH = height - margin.top - margin.bottom;

                    var svg = d3.select(container).append('svg')
                      .attr('width', width).attr('height', height);
                    var g = svg.append('g')
                      .attr('transform', 'translate(' + margin.left + ',' + margin.top + ')');

                    var stack = d3.stack()
                      .keys(keys)
                      .offset(d3.stackOffsetWiggle)
                      .order(d3.stackOrderInsideOut);
                    var series = stack(tableData);

                    var x = d3.scaleTime()
                      .domain(d3.extent(tableData, function(d) { return d.date; }))
                      .range([0, innerW]);
                    var y = d3.scaleLinear()
                      .domain([
                        d3.min(series, function(s) { return d3.min(s, function(d) { return d[0]; }); }),
                        d3.max(series, function(s) { return d3.max(s, function(d) { return d[1]; }); })
                      ])
                      .range([innerH, 0]);

                    var area = d3.area()
                      .x(function(d) { return x(d.data.date); })
                      .y0(function(d) { return y(d[0]); })
                      .y1(function(d) { return y(d[1]); })
                      .curve(d3.curveLinear);

                    g.selectAll('.stream-area')
                      .data(series)
                      .join('path')
                      .attr('class', 'stream-area')
                      .attr('d', area)
                      .attr('fill', function(d) {
                        var cfg = stateConfig[d.key];
                        return cfg ? cfg.color : '#999';
                      })
                      .attr('opacity', 0.85);

                    var crosshair = g.append('line')
                      .attr('y1', 0)
                      .attr('y2', innerH)
                      .attr('stroke', '#94a3b8')
                      .attr('stroke-width', 1)
                      .attr('stroke-dasharray', '4,3')
                      .attr('pointer-events', 'none')
                      .style('display', 'none');

                    g.append('rect')
                      .attr('width', innerW)
                      .attr('height', innerH)
                      .attr('fill', 'none')
                      .attr('pointer-events', 'all')
                      .on('mousemove', function(event) {
                        var gPointer = d3.pointer(event, g.node());
                        var dateIdx = d3.bisectCenter(tableData.map(function(r) { return r.date; }), x.invert(gPointer[0]));
                        var row = tableData[dateIdx];
                        var snappedX = x(row.date);

                        crosshair
                          .attr('x1', snappedX)
                          .attr('x2', snappedX)
                          .style('display', null);

                        var dateStr = row.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
                        var html = '<strong>' + dateStr + '</strong>';
                        keys.forEach(function(k) {
                          var cfg = stateConfig[k] || { label: k, color: '#999' };
                          html += '<br><span style="color:' + cfg.color + '">&#9632;</span> ' + cfg.label + ': ' + row[k];
                        });
                        tooltip.innerHTML = html;

                        var tooltipRect = tooltip.getBoundingClientRect();
                        var containerRect = container.getBoundingClientRect();
                        var cursorXInContainer = snappedX + margin.left;
                        var spaceRight = containerRect.width - cursorXInContainer;

                        if (spaceRight < tooltipRect.width + 20) {
                          tooltip.style.left = (cursorXInContainer - tooltipRect.width - 12) + 'px';
                        } else {
                          tooltip.style.left = (cursorXInContainer + 12) + 'px';
                        }
                        tooltip.style.top = margin.top + 'px';
                        tooltip.classList.add('is-visible');
                      })
                      .on('mouseleave', function() {
                        tooltip.classList.remove('is-visible');
                        crosshair.style('display', 'none');
                      });

                    g.append('g')
                      .attr('transform', 'translate(0,' + innerH + ')')
                      .call(d3.axisBottom(x).ticks(6).tickFormat(d3.timeFormat('%b %d')))
                      .selectAll('text').style('font-size', '7px');

                    g.append('g')
                      .attr('class', 'd3-stream-grid')
                      .call(d3.axisLeft(y).ticks(4).tickSize(-innerW).tickFormat(d3.format('d')))
                      .selectAll('text').style('font-size', '7px');
                  }

                  keys.forEach(function(k) {
                    var cfg = stateConfig[k] || { label: k, color: '#999' };
                    var span = document.createElement('span');
                    span.innerHTML = '<span class="d3-stream-legend__swatch" style="background:' + cfg.color + '"></span>' + cfg.label;
                    legendEl.appendChild(span);
                  });

                  render();
                  window.addEventListener('resize', render);
                });
              });
            </script>
          <% else %>
            <p class="fraud-stats-error">No trend data available</p>
          <% end %>
        </div>
      </div>

      <% if @recent_new_items.present? %>
        <div class="smd-new-items">
          <h3 class="smd-new-items__title">Recently Added Items</h3>
          <div class="smd-new-items__carousel">
            <button class="smd-new-items__arrow smd-new-items__arrow--prev" aria-label="Previous items">‹</button>
            <div class="smd-new-items__track-wrapper">
              <div class="smd-new-items__track">
                <% @recent_new_items.each do |item| %>
                  <% next unless item.image.attached? %>
                  <%= link_to admin_shop_item_path(item), class: "smd-new-items__card" do %>
                    <%= image_tag item.image.variant(:carousel_sm), class: "smd-new-items__image", loading: "lazy" %>
                    <span class="smd-new-items__name"><%= item.name %></span>
                    <span class="smd-new-items__meta"><%= item.type.demodulize.underscore.humanize %> · <%= time_ago_in_words(item.created_at) %> ago</span>
                  <% end %>
                <% end %>
              </div>
            </div>
            <button class="smd-new-items__arrow smd-new-items__arrow--next" aria-label="Next items">›</button>
          </div>
        </div>
        <script>
          document.addEventListener('DOMContentLoaded', function() {
            var wrapper = document.querySelector('.smd-new-items__track-wrapper');
            var prev = document.querySelector('.smd-new-items__arrow--prev');
            var next = document.querySelector('.smd-new-items__arrow--next');
            if (!wrapper || !prev || !next) return;
            var scrollAmount = 260;
            prev.addEventListener('click', function() { wrapper.scrollBy({ left: -scrollAmount, behavior: 'smooth' }); });
            next.addEventListener('click', function() { wrapper.scrollBy({ left: scrollAmount, behavior: 'smooth' }); });
          });
        </script>
      <% end %>
    </div>
