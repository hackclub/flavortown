<div data-controller="fraud">
  <div class="super-mega-dashboard__header super-mega-dashboard__header--fraud">
    <h2>Fraud Overview</h2>
    <div style="display:flex;gap:8px;align-items:center;">
      <%= link_to admin_fraud_dashboard_path, class: "super-mega-link", style: "display:flex;align-items:center;gap:4px;" do %>
        Full Dashboard
      <% end %>
      <%= link_to "https://joe.fraud.hackclub.com/cases/dashboard?ysws=Flavortown", class: "super-mega-link", target: "_blank", style: "display:flex;align-items:center;gap:4px;" do %>
        Joe Dashboard
      <% end %>
      <button type="button" class="super-mega-link" style="display:flex;align-items:center;gap:4px;background:none;border:none;cursor:pointer;" data-action="fraud#openModal" data-fraud-modal-id="vibesModal">
        Vibez
      </button>
    </div>
  </div>

  <%# vibes overview %>
  <div id="vibesModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;overflow-y:auto;" data-action="click->fraud#backdropClose">
    <div class="super-mega-dashboard__card" style="min-width:320px;max-width:860px;max-height:85vh;overflow-y:auto;position:relative;margin:auto;">
      <button data-action="fraud#closeModal" data-fraud-modal-id="vibesModal" style="position:absolute;top:8px;right:12px;background:none;border:none;cursor:pointer;font-size:16px;color:#94a3b8;">✕</button>
      <h3>Vibez</h3>

      <%# current week feedback %>
      <div id="vibesWeekModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;overflow-y:auto;" data-action="click->fraud#backdropClose">
        <div class="super-mega-dashboard__card" style="min-width:320px;max-width:560px;max-height:80vh;overflow-y:auto;position:relative;margin:auto;">
          <button data-action="fraud#closeModal" data-fraud-modal-id="vibesWeekModal" style="position:absolute;top:8px;right:12px;background:none;border:none;cursor:pointer;font-size:16px;color:#94a3b8;">✕</button>
          <h3><%= @fraud_happiness_week %> Feedback</h3>
          <% feedback_records = @fraud_happiness_records.select { |r| r[:extra_comments].present? } %>
          <% if feedback_records.any? %>
            <% feedback_records.each do |r| %>
              <div style="border-top:1px solid #1e293b;padding:8px 0;display:flex;align-items:flex-start;gap:6px;">
                <% if r[:feedback_impl] %>
                  <span title="Feedback implemented" style="color:#10b981;flex-shrink:0;">✓</span>
                <% end %>
                <span style="font-size:11px;color:#000;"><%= r[:extra_comments] %></span>
              </div>
            <% end %>
          <% else %>
            <p class="fraud-stats-grid__label">nobody shared their thoughts with me :<<<< p>
          <% end %>
        </div>
      </div>

      <%# Modal: all weeks feedback %>
      <div id="vibesAllWeeksModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;overflow-y:auto;" data-action="click->fraud#backdropClose">
        <div class="super-mega-dashboard__card" style="min-width:320px;max-width:600px;max-height:85vh;overflow-y:auto;position:relative;margin:auto;">
          <button data-action="fraud#closeModal" data-fraud-modal-id="vibesAllWeeksModal" style="position:absolute;top:8px;right:12px;background:none;border:none;cursor:pointer;font-size:16px;color:#94a3b8;">✕</button>
          <h3>All Weeks Feedback</h3>
          <% @fraud_vibes_history&.sort_by { |w, _| w }.each do |week, data| %>
            <details style="border-top:1px solid #1e293b;padding:6px 0;">
              <summary style="cursor:pointer;font-weight:600;font-size:12px;"><%= week %> <span style="color:#94a3b8;font-weight:400;">(<%= data[:responses] %> responses)</span></summary>
              <% (data[:records] || []).select { |r| r[:extra_comments].present? }.each do |r| %>
                <div style="padding:6px 0 6px 12px;border-top:1px solid #0f172a;display:flex;align-items:flex-start;gap:6px;">
                  <% if r[:feedback_impl] %>
                    <span title="Feedback implemented" style="color:#10b981;flex-shrink:0;">✓</span>
                  <% end %>
                  <span style="font-size:11px;color:#000;"><%= r[:extra_comments] %></span>
                </div>
              <% end %>
            </details>
          <% end %>
        </div>
      </div>

      <div class="super-mega-dashboard__cards">
        <div class="super-mega-dashboard__card" style="cursor:pointer;" data-action="fraud#openModal" data-fraud-modal-id="vibesWeekModal">
          <%= render FraudHappinessComponent.new(
            week: @fraud_happiness_week,
            records: @fraud_happiness_records,
            avg_scores: @fraud_happiness_avg_scores,
            error: @fraud_happiness_error,
            prev_scores: @fraud_happiness_prev_scores,
            description: "The team's overall vibe for the current week, based off there feedback. Click to read comments and see trends over time.",
          ) %>
        </div>
        <% if @fraud_vibes_history.present? %>
          <div class="super-mega-dashboard__card super-mega-dashboard__card--mini-graph" style="cursor:pointer;" data-action="fraud#openModal" data-fraud-modal-id="vibesAllWeeksModal">
            <h3>Vibes Over Time <svg style="height: 16px;" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.5" />
                <path d="M12 16.25v-5M12 7.75h.008" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
              </svg></h3>
            <div class="d3-stream-container" id="vibesTrendContainer" data-fraud-dash-vibes-history="<%= json_escape(@fraud_vibes_history.to_json) %>">
              <div class="d3-stream-tooltip" id="vibesTrendTooltip"></div>
            </div>
            <div class="d3-stream-legend" id="vibesTrendLegend"></div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- PENDING QUEUE -->
  <div class="fraud-subsection">
    <h3 class="fraud-subsection__title">Pending Queue</h3>
    <div class="super-mega-dashboard__cards">
      <div class="super-mega-dashboard__card">
        <h3>Awaiting Review</h3>
        <% pending_color = ->(n) { n >= 100 ? "red" : n >= 50 ? "yellow" : "green" } %>
        <div class="fraud-stats-grid">
          <div class="fraud-stats-grid__row">
            <span class="fraud-stats-grid__label">Reports Pending</span>
            <% rp = @fraud_reports[:pending] || 0 %>
            <span class="fraud-stats-grid__value fraud-stats-grid__value--<%= pending_color.call(rp) %>"><%= rp %></span>
          </div>
          <div class="fraud-stats-grid__row">
            <span class="fraud-stats-grid__label">Shop Orders Pending</span>
            <% sop = @fraud_orders[:pending] || 0 %>
            <span class="fraud-stats-grid__value fraud-stats-grid__value--<%= pending_color.call(sop) %>"><%= sop %></span>
          </div>
        </div>
      </div>
      <%# Move Stalest Cases card here to share row %>
      <div class="super-mega-dashboard__card">
        <h3>Stalest Cases</h3>
        <% if @joe_fraud_stats.nil? %>
          <p class="fraud-stats-error">No Joe stats available</p>
        <% elsif @joe_fraud_stats[:error] %>
          <p class="fraud-stats-error"><%= @joe_fraud_stats[:error] %></p>
        <% else %>
          <% stale_cases = @joe_fraud_stats[:longest_hang_times]&.select { |c| c[:status] == "open" } || [] %>
          <% if stale_cases.any? %>
            <div class="fraud-stats-grid">
              <% stale_cases.each do |c| %>
                <div class="fraud-stats-grid__row">
                  <a href="https://joe.fraud.hackclub.com/cases/<%= c[:id] %>" target="_blank" style="color:inherit;text-decoration:none;flex:1;display:flex;align-items:center;justify-content:space-between;gap:8px;">
                    <span class="fraud-stats-grid__label" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:160px;" title="<%= c[:snippet] %>">#<%= c[:id] %> — <%= c[:snippet]&.split("\n")&.first %></span>
                    <span class="fraud-stats-grid__value fraud-stats-grid__value--red" style="flex-shrink:0;"><%= c[:hangDays] %>d</span>
                  </a>
                </div>
              <% end %>
            </div>
          <% else %>
            <p class="fraud-stats-grid__label">we aint stale! 🎉</p>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- JOE SECTION -->
  <div class="fraud-subsection">
    <h3 class="fraud-subsection__title">Cases & Bans</h3>
    <div class="super-mega-dashboard__cards" style="display:flex;gap:16px;">
      <div class="super-mega-dashboard__card super-mega-dashboard__card--mini-graph" style="flex:1 1 0;min-width:0;max-width:50%;">
        <h3>Unresolved Cases vs Hang Time</h3>
        <% if @joe_fraud_stats && !@joe_fraud_stats[:error] && @joe_fraud_stats[:created_over_time].any? %>
          <div class="d3-stream-container" id="joeUnresolvedContainer" data-fraud-dash-joe-created-over-time="<%= json_escape(@joe_fraud_stats[:created_over_time].to_json) %>" data-fraud-dash-joe-avg-hang-time-days="<%= json_escape(@joe_fraud_stats[:avg_hang_time_days].to_json) %>" data-fraud-dash-joe-open-count="<%= json_escape(@joe_fraud_stats[:open].to_json) %>" data-fraud-dash-joe-waiting-count="<%= json_escape(@joe_fraud_stats[:waiting].to_json) %>">
            <div class="d3-stream-tooltip" id="joeUnresolvedTooltip"></div>
          </div>
          <div class="d3-stream-legend" id="joeUnresolvedLegend"></div>
        <% else %>
          <p class="fraud-stats-error"><%= @joe_fraud_stats&.dig(:error) || "No Joe data" %></p>
        <% end %>
      </div>
      <div class="super-mega-dashboard__card super-mega-dashboard__card--mini-graph" id="banTrendCard" style="flex:1 1 0;min-width:0;max-width:50%;cursor:pointer;" data-action="fraud#openModal" data-fraud-modal-id="banStatsModal">
        <h3>Bans Over Time <svg style="height: 16px;" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.5" />
            <path d="M12 16.25v-5M12 7.75h.008" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          </svg></h3>
        <% if @fraud_ban_trend_data.present? %>
          <div class="d3-stream-container" id="banTrendContainer" data-fraud-dash-ban-trend="<%= json_escape(@fraud_ban_trend_data.to_json) %>">
            <div class="d3-stream-tooltip" id="banTrendTooltip"></div>
          </div>
          <div class="d3-stream-legend" id="banTrendLegend"></div>
        <% else %>
          <p class="fraud-stats-error">No trend data available</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- REPORTS SECTION -->
  <div class="fraud-subsection">
    <h3 class="fraud-subsection__title">Reports</h3>
    <div class="super-mega-dashboard__cards">
      <div id="reportStatsModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;" data-action="click->fraud#backdropClose">
        <div class="super-mega-dashboard__card" style="min-width:260px;position:relative;">
          <button data-action="fraud#closeModal" data-fraud-modal-id="reportStatsModal" style="position:absolute;top:8px;right:12px;background:none;border:none;cursor:pointer;font-size:16px;color:#94a3b8;">✕</button>
          <h3>Report Stats</h3>
          <div class="fraud-stats-grid">
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">New Today</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--blue"><%= @fraud_reports[:new_today] %></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Pending</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--yellow"><%= @fraud_reports[:pending] %><span class="fraud-stats-grid__pct">(<%= @fraud_reports[:pending_pct] %>%)</span></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Reviewed</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--red"><%= @fraud_reports[:reviewed] %><span class="fraud-stats-grid__pct">(<%= @fraud_reports[:reviewed_pct] %>%)</span></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Dismissed</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--green"><%= @fraud_reports[:dismissed] %><span class="fraud-stats-grid__pct">(<%= @fraud_reports[:dismissed_pct] %>%)</span></span>
            </div>
          </div>
        </div>
      </div>
      <div id="banStatsModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:1000;align-items:center;justify-content:center;" data-action="click->fraud#backdropClose">
        <div class="super-mega-dashboard__card" style="min-width:260px;position:relative;">
          <button data-action="fraud#closeModal" data-fraud-modal-id="banStatsModal" style="position:absolute;top:8px;right:12px;background:none;border:none;cursor:pointer;font-size:16px;color:#94a3b8;">✕</button>
          <h3>Ban Stats (all time)</h3>
          <div class="fraud-stats-grid">
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Banned</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--red"><%= @fraud_bans[:banned] %><span class="fraud-stats-grid__pct">(<%= @fraud_bans[:banned_pct] %>%)</span></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Shadow Banned (Projects)</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--purple"><%= @fraud_bans[:shadow_banned_users] %><span class="fraud-stats-grid__pct">(<%= @fraud_bans[:shadow_banned_pct] %>%)</span></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">Unbanned</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--green"><%= @fraud_bans[:unbanned] %></span>
            </div>
            <div class="fraud-stats-grid__row">
              <span class="fraud-stats-grid__label">% of Users Banned</span>
              <span class="fraud-stats-grid__value fraud-stats-grid__value--red"><%= @fraud_bans[:ban_unban_ratio] %>%</span>
            </div>
          </div>
        </div>
      </div>
      <div class="super-mega-dashboard__card super-mega-dashboard__card--mini-graph" style="cursor:pointer;" data-action="fraud#openModal" data-fraud-modal-id="reportStatsModal">
        <h3>Reports Over Time (by reason) <svg style="height: 16px;" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <circle cx="12" cy="12" r="9.25" stroke="currentColor" stroke-width="1.5" />
            <path d="M12 16.25v-5M12 7.75h.008" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" />
          </svg></h3>
        <% if @fraud_report_trend_data.present? %>
          <div class="d3-stream-container" id="reportTrendContainer" data-fraud-dash-report-trend="<%= json_escape(@fraud_report_trend_data.to_json) %>">
            <div class="d3-stream-tooltip" id="reportTrendTooltip"></div>
          </div>
          <div class="d3-stream-legend" id="reportTrendLegend"></div>
        <% else %>
          <p class="fraud-stats-error">No data available</p>
        <% end %>
      </div>
    </div>
  </div>
</div>
