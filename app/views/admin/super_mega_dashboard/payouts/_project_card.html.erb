<div class="payout-project-card">
  <% variant = (local_assigns[:variant] || :most_cookies).to_sym %>
  <% show_multiplier = (variant == :highest_multiplier) %>
  <% show_total_payout = (variant == :most_cookies) %>

  <div class="payout-project-card__banner">
    <%= link_to project_path(project_data[:project_id]), class: "payout-project-card__banner-link", target: "_blank", rel: "noopener" do %>
      <% if project_data[:project]&.banner&.attached? %>
        <%= image_tag project_data[:project].banner.variant(:card), alt: "#{project_data[:title]} banner", class: "payout-project-card__banner-image" %>
      <% else %>
        <%= image_tag "default-banner.png", alt: "#{project_data[:title]} banner", class: "payout-project-card__banner-image" %>
      <% end %>
    <% end %>

    <% if project_data[:creator]&.id.present? %>
      <%= link_to user_path(project_data[:creator].id), class: "payout-project-card__creator-badge", title: project_data[:creator].display_name, target: "_blank", rel: "noopener" do %>
        <%= image_tag project_data[:creator].avatar, alt: project_data[:creator].display_name, class: "payout-project-card__creator-avatar" %>
      <% end %>
    <% end %>
  </div>

  <div class="payout-project-card__content">
    <div class="payout-project-card__title">
      <%= link_to project_path(project_data[:project_id]), class: "payout-project-card__title-link", target: "_blank", rel: "noopener" do %>
        <%= project_data[:title] %>
      <% end %>
    </div>

    <% if show_multiplier %>
      <div class="payout-project-card__metric payout-project-card__metric--cookies">
        <%= project_data[:max_multiplier] %> 🍪/hr
      </div>
    <% elsif show_total_payout %>
      <div class="payout-project-card__metric payout-project-card__metric--cookies">
        <%= number_with_delimiter(project_data[:total_payout]) %> 🍪
      </div>
    <% end %>
  </div>
</div>
