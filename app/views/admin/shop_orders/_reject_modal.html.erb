<%= render ModalComponent.new(id: "reject-modal", title: "Reject Order ##{order.id}") do |modal| %>
  <%= form_with url: reject_admin_shop_order_path(order), method: :post, local: true do |f| %>
    <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
    <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>
    <div class="modal__field">
      <%= f.label :reason, "Rejection Reason" %>
      <%= f.text_area :reason, placeholder: "Enter reason for rejection...", rows: 4 %>
    </div>

    <% modal.with_submit_and_cancel(submit_text: "Reject Order") %>
  <% end %>
<% end %>
