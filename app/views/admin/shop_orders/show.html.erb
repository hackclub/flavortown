<% content_for :title, "Order ##{@order.id}" %>
<h1 class="admin-section__header" style="font-size: 1.5rem; margin-bottom: 1rem;">
  <span
    title="ID: <%= @order.id %>&#10;User: <%= @order.user.display_name %><%= " (Slack: #{@order.user.slack_id || 'N/A'})" unless current_user.shop_manager? && !current_user.admin? %>&#10;Item: <%= @order.shop_item.name %>&#10;Qty: <%= @order.quantity %> × <%= @order.frozen_item_price %> = <%= @order.total_cost %> tickets&#10;Status: <%= @order.aasm_state.humanize %>&#10;Created: <%= @order.created_at.strftime('%Y-%m-%d %H:%M') %><%= @order.assigned_to_user.present? ? "&#10;Assigned: #{@order.assigned_to_user.display_name}" : '' %>"
    style="cursor: help;">Order #<%= @order.id %></span>
</h1>

<% if @other_viewers.any? %>
  <div class="admin-alert admin-alert--warning">
    👀 <%= @other_viewers.to_sentence %> <%= @other_viewers.one? ? "is" : "are" %> also looking at this order
  </div>
<% end %>

<%= render "shared/admin_state_machine", record: @order %>

<div class="admin-section">
  <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center;">
    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">Status</span>
      <span class="badge badge-<%= @order.aasm_state %>" style="font-size: 0.75rem; padding: 0.2rem 0.4rem;">
        <%= @order.aasm_state.humanize %>
      </span>
    </div>

    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">Created</span>
      <span style="font-size: 0.875rem;"><%= @order.created_at.strftime("%m/%d %l:%M%p") %></span>
    </div>

    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">User</span>
      <%= link_to @order.user.display_name || "Unknown", admin_user_path(@order.user), style: "font-size: 0.875rem; color: #3b82f6;" %>
      <% unless current_user.shop_manager? && !current_user.admin? %>
        <div style="font-size: 0.7rem; color: #6b7280; margin-top: 0.25rem;">
          <div>Slack: <% if @order.user.slack_id.present? %><a href="https://hackclub.slack.com/team/<%= @order.user.slack_id %>" target="_blank" style="color: #3b82f6;"><code><%= @order.user.slack_id %></code></a><% else %><span style="color: #9ca3af;">N/A</span><% end %></div>
          <% hackatime_identity = @order.user.identities.find { |i| i.provider == "hackatime" } %>
          <% if hackatime_identity %>
            <div>Hackatime: <code><%= hackatime_identity.uid %></code></div>
          <% end %>
          <% hack_club_identity = @order.user.identities.find { |i| i.provider == "hack_club" } %>
          <% if hack_club_identity %>
            <div>Hack Club: <code><%= hack_club_identity.uid %></code></div>
          <% end %>
        </div>
      <% end %>
      <% if current_user.admin? || current_user.fraud_dept? %>
        <div style="display: flex; gap: 0.25rem; margin-top: 0.25rem;">
          <% if hackatime_identity %>
            <%= link_to "Billy", "https://billy.3kh0.net/?u=#{hackatime_identity.uid}", class: "btn-primary slim", target: "_blank", style: "font-size: 0.65rem; padding: 0.15rem 0.3rem;" %>
            <%= link_to "Joe", "https://joe.fraud.hackclub.com/profile/#{hackatime_identity.uid}", class: "btn-primary slim", target: "_blank", style: "font-size: 0.65rem; padding: 0.15rem 0.3rem;" %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">Item</span>
      <span style="font-size: 0.875rem;"><%= truncate(@order.shop_item.name, length: 25) %></span>
    </div>

    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">Quantity</span>
      <span style="font-size: 1.25rem; font-weight: 700;<%= ' color: #dc2626;' if @order.quantity > 1 %>">
        ×<%= @order.quantity %>
      </span>
      <% if @order.quantity > 1 %>
        <span class="badge" style="background: #fef2f2; color: #dc2626; font-size: 0.65rem; margin-left: 0.25rem;">MORE THAN ONE</span>
      <% end %>
    </div>

    <div>
      <span style="font-size: 0.75rem; color: #6b7280; display: block;">Cost</span>
      <span style="font-size: 0.875rem;">
        <%= @order.quantity %> × <%= @order.frozen_item_price %> tickets
        = <strong style="color: #15803d;"><%= @order.total_cost %> total</strong>
      </span>
    </div>
  </div>
</div>

<div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
  <div class="admin-section" style="flex: 1; margin-bottom: 0;">
    <h2 class="admin-section__header admin-section__header--purple">Shop Orders Summary</h2>
    <div style="font-size: 0.875rem; line-height: 1.6;">
      <div><strong>Total Orders:</strong> <%= @user_order_stats[:total] %></div>
      <div><strong>Fulfilled:</strong> <%= @user_order_stats[:fulfilled] %></div>
      <div><strong>Pending:</strong> <%= @user_order_stats[:pending] %></div>
      <div><strong>Rejected:</strong> <%= @user_order_stats[:rejected] %></div>
      <div><strong>Total Quantity:</strong> <%= @user_order_stats[:total_quantity] %></div>
      <div><strong>On Hold:</strong> <%= @user_order_stats[:on_hold] %></div>
      <div><strong>Awaiting Fulfillment:</strong> <%= @user_order_stats[:awaiting_fulfillment] %></div>
    </div>
    <% if @user_orders.present? %>
      <details style="margin-top: 0.75rem; cursor: pointer;">
        <summary style="font-size: 0.8rem; color: #6b7280;">▸ View All Orders (<%= @user_order_stats[:total] %>)</summary>
        <div style="padding-top: 0.5rem; font-size: 0.75rem;">
          <% @order.user.shop_orders.order(created_at: :desc).each do |order| %>
            <div style="padding: 0.25rem 0; border-bottom: 1px solid #374151;">
              <%= link_to "##{order.id}", admin_shop_order_path(order), style: "color: #3b82f6;" %>
              - <%= truncate(order.shop_item.name, length: 15) %>
              <span class="badge badge-<%= order.aasm_state %>" style="font-size: 0.6rem; padding: 0.1rem 0.25rem;"><%= order.aasm_state.humanize %></span>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>

  <div class="admin-section" style="flex: 1; margin-bottom: 0;">
    <h2 class="admin-section__header admin-section__header--purple">Shop Item</h2>
    <% item = @order.shop_item %>
    <%= link_to item.name, "#", style: "color: #60a5fa; font-size: 0.95rem; text-decoration: underline;" %>
    <div style="font-size: 0.875rem; line-height: 1.6; margin-top: 0.5rem;">
      <div><strong>Description:</strong> <%= item.description %></div>
      <div><strong>Internal description:</strong> <%= item.internal_description %></div>
      <% regional_usd_offset = @order.region.present? ? (item.send("usd_offset_#{@order.region.downcase}") || item.send("usd_offset_xx") || 0) : 0 %>
      <div><strong>USD cost:</strong> $<%= number_with_precision((item.usd_cost || 0) + regional_usd_offset, precision: 2) %>
        <% if regional_usd_offset != 0 %>
          <small style="color: #6b7280;">(base $<%= number_with_precision(item.usd_cost, precision: 2) %> + $<%= number_with_precision(regional_usd_offset, precision: 2) %> <%= @order.region %> offset)</small>
        <% end %>
      </div>
      <% displayed_frozen_ticket_cost = number_with_precision(@order.frozen_item_price || 0, precision: 0) %>
      <% displayed_base_ticket_cost   = number_with_precision(item.ticket_cost || 0, precision: 0) %>
      <div><strong>Ticket cost:</strong> <%= displayed_frozen_ticket_cost %>
        <% if displayed_frozen_ticket_cost.to_i != displayed_base_ticket_cost.to_i %>
          <small style="color: #6b7280;">(base: <%= displayed_base_ticket_cost %>)</small>
        <% end %>
      </div>
      <div><strong>Type:</strong> <%= item.type %></div>
    </div>
    <% if item.image.attached? %>
      <div style="margin-top: 0.75rem;">
        <%= image_tag item.image.variant(:carousel_sm), style: "max-width: 120px; border-radius: 4px;" %>
      </div>
    <% end %>
  </div>
</div>

<% if @order.parent_order.present? %>
<div class="admin-section" style="border-left: 4px solid #f59e0b;">
  <h2 class="admin-section__header admin-section__header--amber">🔗 This is an Accessory Order</h2>
  <div style="font-size: 0.875rem;">
    <p style="margin: 0;">This accessory was ordered with:</p>
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-top: 0.5rem; padding: 0.5rem; background: #fffbeb; border-radius: 4px;">
      <% if @order.parent_order.shop_item.image.attached? %>
        <%= image_tag @order.parent_order.shop_item.image.variant(:carousel_sm), style: "width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" %>
      <% end %>
      <div>
        <strong><%= @order.parent_order.shop_item.name %></strong>
        <br>
        <%= link_to "View Parent Order ##{@order.parent_order.id}", admin_shop_order_path(@order.parent_order), style: "color: #3b82f6; font-size: 0.8rem;" %>
      </div>
    </div>
  </div>
</div>
<% end %>

<% if @order.accessory_orders.any? %>
<div class="admin-section" style="border-left: 4px solid #10b981;">
  <h2 class="admin-section__header admin-section__header--green">🎁 Accessories Ordered</h2>
  <div style="display: flex; flex-direction: column; gap: 0.5rem;">
    <% @order.accessory_orders.includes(shop_item: { image_attachment: :blob }).each do |acc_order| %>
      <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.5rem; background: #f0fdf4; border-radius: 4px;">
        <% if acc_order.shop_item.image.attached? %>
          <%= image_tag acc_order.shop_item.image.variant(:carousel_sm), style: "width: 50px; height: 50px; object-fit: cover; border-radius: 4px;" %>
        <% end %>
        <div style="flex: 1;">
          <strong><%= acc_order.shop_item.name %></strong>
          <br>
          <small style="color: #6b7280;">🍪 <%= acc_order.frozen_item_price || acc_order.shop_item.ticket_cost %></small>
        </div>
        <div>
          <span class="badge badge-<%= acc_order.aasm_state %>" style="font-size: 0.7rem;">
            <%= acc_order.aasm_state.humanize %>
          </span>
        </div>
        <div>
          <%= link_to "View", admin_shop_order_path(acc_order), class: "btn-primary slim", style: "font-size: 0.75rem; padding: 0.2rem 0.5rem;" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<% if @can_view_address %>
<div class="admin-section">
  <h2 class="admin-section__header">Shipping Address</h2>
  <% if @is_digital_fulfillment_type && current_user.admin? %>
    <div style="margin-bottom: 1em; padding: 0.5em; background: #dbeafe; border-radius: 4px;">
      <small style="color: #1e40af;">
        ℹ️ This is a digital fulfillment item. Address visible because you are an admin.
      </small>
    </div>
  <% end %>
  <% if @can_view_address %>
    <div id="address-container">

      <turbo-frame id="address-content"> <div style="padding: 1em; background: #f3f4f6; border-radius: 4px; text-align: center;">
        <p style="margin: 0 0 1em 0; color: #374151;">
          🔒 Address is encrypted. Click below to decrypt and view.
        </p>
        <%= button_to "Reveal Address", reveal_address_admin_shop_order_path(@order),
            method: :post,
            class: "btn-primary",
            data: {
              turbo_frame: "address-content",
              turbo_method: "post"
            } %>
      </div></turbo-frame>
      <turbo-frame id="phone-content">
        <div style="padding: 1em; background: #f3f4f6; border-radius: 4px; text-align: center; margin-top: 1em;">
          <p style="margin: 0 0 1em 0; color: #374151;">
            📱 Phone number is encrypted. Click below to decrypt and view.
          </p>
          <%= button_to "Reveal Phone Number", reveal_phone_admin_shop_order_path(@order),
              method: :post,
              class: "btn-primary",
              data: {
                turbo_frame: "phone-content",
                turbo_method: "post"
              } %>
        </div>
      </turbo-frame>
    </div>
  <% else %>
    <div style="padding: 1em; background: #fee2e2; border-radius: 4px;">
      <p style="color: #991b1b; margin: 0;">
        🔒 You do not have permission to view this address. Only admins and fulfillment persons in the order's region can access this information.
      </p>
    </div>
  <% end %>
</div>
<% end %>

<div class="admin-section">
  <h2 class="admin-section__header">Fulfillment Information</h2>
  <div class="info-rows">
    <% if current_user.admin? || current_user.fulfillment_person? %>
      <div style="margin-bottom: 1rem;">
        <b>Assigned To:</b>
        <% if @order.assigned_to_user.present? %>
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; margin-left: 0.5rem;">
            <%= image_tag @order.assigned_to_user.avatar, alt: @order.assigned_to_user.display_name, style: "width: 24px; height: 24px; border-radius: 50%; object-fit: cover;" %>
            <span><%= @order.assigned_to_user.display_name %></span>
            <% if @order.assigned_to_user.has_regions? %>
              <span style="background: #e0f2fe; color: #0369a1; padding: 0.125rem 0.5rem; border-radius: 9999px; font-size: 0.7rem;">
                <%= @order.assigned_to_user.regions.join(", ") %>
              </span>
            <% end %>
          </div>
        <% else %>
          <span style="color: #9ca3af; margin-left: 0.5rem;">Unassigned</span>
        <% end %>

        <div data-controller="searchable-select" style="position: relative; margin-top: 0.5rem; max-width: 250px;">
          <%= form_with url: assign_user_admin_shop_order_path(@order), method: :post, local: true, data: { turbo: false } do |f| %>
            <%= f.hidden_field :assigned_to_user_id, value: @order.assigned_to_user_id, data: { searchable_select_target: "hiddenField" } %>
            <input
              type="text"
              class="form-control"
              placeholder="<%= @order.assigned_to_user.present? ? 'Change assignee...' : 'Assign someone...' %>"
              style="padding: 0.4rem 0.75rem; font-size: 0.85rem;"
              data-searchable-select-target="input"
              data-action="focus->searchable-select#open input->searchable-select#filter"
              autocomplete="off">
            <div data-searchable-select-target="dropdown" class="searchable-select-dropdown">
              <div
                class="searchable-select-option"
                data-searchable-select-target="option"
                data-action="click->searchable-select#selectAndSubmit"
                data-value=""
                data-label=""
                data-search-text="unassigned none remove">
                <span style="color: #9ca3af;">Unassign</span>
              </div>
              <% @fulfillment_users.each do |user| %>
                <div
                  class="searchable-select-option <%= 'selected' if user.id == @order.assigned_to_user_id %>"
                  data-searchable-select-target="option"
                  data-action="click->searchable-select#selectAndSubmit"
                  data-value="<%= user.id %>"
                  data-label="<%= user.display_name %>"
                  data-search-text="<%= "#{user.display_name} #{user.regions.join(' ')} #{user.id}".downcase %>">
                  <img src="<%= user.avatar %>" alt="" class="searchable-select-avatar">
                  <span><%= user.display_name %></span>
                  <% if user.has_regions? %>
                    <span style="font-size: 0.7rem; color: #6b7280; margin-left: auto;"><%= user.regions.join(", ") %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
    <% if @order.external_ref.present? %>
      <div>
        <b>Tracking/External Reference:</b>
        <% if @order.shop_item.type.in?(%w[ShopItem::LetterMail ShopItem::FreeStickers]) %>
          <a href="<%= "https://mail.hackclub.com/back_office/letters/#{@order.external_ref}" %>" target="_blank"><%= @order.external_ref %></a>
        <% else %>
          <%= @order.external_ref %>
        <% end %>
      </div>
    <% end %>
    <% if @order.fulfilled_by.present? %>
      <div><b>Fulfilled By:</b> <%= @order.fulfilled_by %></div>
    <% end %>
    <% if @order.fulfillment_cost.present? && @order.fulfillment_cost > 0 %>
      <div><b>Fulfillment Cost:</b> $<%= number_to_currency(@order.fulfillment_cost, precision: 2, unit: "") %></div>
    <% end %>
    <% if @order.rejection_reason.present? %>
      <div><b>Rejection Reason:</b> <%= @order.rejection_reason %></div>
    <% end %>
    <% if @order.internal_rejection_reason.present? %>
      <div><b>Internal Reason:</b> <%= @order.internal_rejection_reason %></div>
    <% end %>
    <% if @order.fraud_related_project_id.present? %>
      <div><b>Related Project:</b> <%= link_to "##{@order.fraud_related_project_id}", project_path(@order.fraud_related_project_id) %></div>
    <% end %>
    <% if @order.joe_case_url.present? %>
      <div>
        <b>Joe Case:</b>
        <% begin %>
          <% uri = URI.parse(@order.joe_case_url.to_s) %>
          <% if uri.is_a?(URI::HTTP) && uri.host.present? %>
            <%= link_to @order.joe_case_url, uri.to_s, target: "_blank", rel: "noopener" %>
          <% else %>
            <%= @order.joe_case_url %>
          <% end %>
        <% rescue URI::InvalidURIError %>
          <%= @order.joe_case_url %>
        <% end %>
      </div>
    <% end %>
    <% if @order.internal_notes.present? %>
      <div><b>Internal Notes:</b> <%= @order.internal_notes %></div>
    <% end %>
  </div>
</div>

<% if @order.shop_card_grant_id.present? %>
  <div class="admin-section">
    <h2 class="admin-section__header">Card Grant</h2>
    <div class="info-rows">
      <div><b>Card Grant ID:</b> <%= @order.shop_card_grant_id %></div>
      <% if @order.shop_card_grant&.hcb_grant_hashid.present? %>
        <div><b>HCB Grant ID:</b> <%= @order.shop_card_grant.hcb_grant_hashid %></div>
        <div>
          <%= link_to "View on HCB", @order.shop_card_grant.hcb_url, target: "_blank", class: "btn-primary", style: "margin-right: 0.5rem;" %>
          <% if current_user.admin? && @order.fulfilled? %>
            <form method="post" action="<%= cancel_hcb_grant_admin_shop_order_path(@order) %>" style="display: inline;">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <button type="submit" class="btn-danger" onclick="return confirm('Are you sure you want to cancel this HCB grant? This cannot be undone.')">Cancel HCB Grant</button>
            </form>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @order.warehouse_package_id.present? %>
  <div class="admin-section">
    <h2 class="admin-section__header">Warehouse Package</h2>
    <div class="info-rows">
      <div><b>Package ID:</b> <%= @order.warehouse_package_id %></div>
    </div>
  </div>
<% end %>

<div class="admin-section" style="width: 50%;">
  <h2 class="admin-section__header">Actions</h2>
  <% if @order.reviews.any? %>
    <div class="review-list">
      <% @order.reviews.includes(:user).each do |review| %>
        <div class="review-list__item review-list__item--<%= review.verdict %>">
          <strong><%= review.user.display_name %></strong> — <%= review.verdict == "approve" ? "✓ Approve" : "✗ Reject" %>
          <p><%= review.reason %></p>
          <small><%= review.created_at.strftime("%m/%d %l:%M%p") %></small>
        </div>
      <% end %>
    </div>
  <% end %>

  <% unless current_user.shop_manager? && !current_user.admin? %>
    <% if @order.high_value? && @order.pending? %>
      <div class="admin-alert admin-alert--warning">
        ⚠️ High-value order (<%= @order.total_cost_with_accessories %> tickets) — requires 2 fraud dept reviews before approval (<%= @order.reviews.count %>/2).
      </div>

      <% unless @order.reviews.exists?(user: current_user) %>
        <%= form_with url: review_order_admin_shop_order_path(@order), method: :post, local: true, class: "review-form" do |f| %>
          <div class="reject-modal__field">
            <label>Your verdict</label>
            <div class="review-form__verdicts">
              <label class="review-form__verdict">
                <%= radio_button_tag :verdict, "approve", false, required: true %>
                ✓ Approve
              </label>
              <label class="review-form__verdict">
                <%= radio_button_tag :verdict, "reject", false, required: true %>
                ✗ Reject
              </label>
            </div>
          </div>
          <div class="reject-modal__field">
            <%= f.label :review_reason, "Reason (required)" %>
            <%= text_area_tag :review_reason, nil, placeholder: "Why are you approving or rejecting this order?", rows: 3, required: true %>
          </div>
          <%= f.submit "Submit Review", class: "admin-btn admin-btn--primary" %>
        <% end %>
      <% end %>
    <% end %>
  <% end %>

  <div class="admin-button-grid">
    <%= link_to "← Back", admin_shop_orders_path, class: "admin-btn admin-btn--secondary" %>
    <% unless current_user.fulfillment_person? %>
      <%= link_to "View User", admin_user_path(@order.user), class: "admin-btn admin-btn--primary" %>
    <% end %>

    <% unless current_user.shop_manager? && !current_user.admin? %>
    <form method="post" action="<%= approve_admin_shop_order_path(@order) %>">
      <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
      <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
      <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>
      <div style="display: flex; gap: 0.5rem; align-items: center; margin-bottom: 0.5rem;">
        <input type="text" name="tracking_number" placeholder="Tracking # (optional)" autocomplete="off" style="padding: 0.4rem; font-size: 0.85rem; width: 180px;">
        <button type="submit" class="admin-btn admin-btn--primary" <% unless (@order.pending? || @order.awaiting_verification_call?) && !@order.requires_additional_review? %> disabled<% end %> onclick="return confirm('Approve this order for fulfillment?')">✓ Approve</button>
      </div>
    </form>

    <%# Reject button for all non-fulfilled states %>
    <% if %w[pending awaiting_verification awaiting_verification_call awaiting_periodical_fulfillment on_hold].include?(@order.aasm_state) %>
      <button type="button" onclick="document.getElementById('reject-modal').showModal()" class="admin-btn admin-btn--danger" <% if @order.requires_additional_review? %> disabled<% end %>>✗ Reject</button>
      <%= render "reject_modal", order: @order %>
    <% end %>

    <%# Refresh verification button for awaiting_verification state %>
    <% if @order.awaiting_verification? %>
      <form method="post" action="<%= refresh_verification_admin_shop_order_path(@order) %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="admin-btn admin-btn--primary" onclick="return confirm('Refresh verification status for this user?')">🔄 Refresh Verification</button>
      </form>
    <% end %>

    <% if (@order.pending? || @order.awaiting_verification? || @order.awaiting_verification_call? || @order.awaiting_periodical_fulfillment?) && !current_user.fulfillment_person? %>
      <form method="post" action="<%= place_on_hold_admin_shop_order_path(@order) %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
        <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>
        <button type="submit" class="admin-btn admin-btn--secondary" onclick="return confirm('Place this order on hold?')">⏸ Hold</button>
      </form>
    <% end %>

    <% if @order.awaiting_verification_call? && current_user.admin? %>
      <form method="post" action="<%= approve_verification_call_admin_shop_order_path(@order) %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
        <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>
        <button type="submit" class="admin-btn admin-btn--primary">I have verified this person is legit</button>
      </form>

      <% m = 'verification-call-fulfillment-modal' %>
      <button type="button" class="admin-btn admin-btn--primary" onclick="document.getElementById(<%= m.to_json %>).showModal()">✓ Mark as Fulfilled</button>
      <dialog id="<%= m %>" class="fulfill-dialog">
        <h3>Mark verification call order fulfilled</h3>
        <form method="post" action="<%= mark_fulfilled_admin_shop_order_path(@order) %>">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <label>Spent (USD)<input type="number" name="fulfillment_cost" step="0.01" min="0" placeholder="0.00" autocomplete="off"></label>
          <label>Order #<input type="text" name="external_ref" placeholder="e.g. ORD-12345" autocomplete="off"></label>
          <div class="fulfill-actions">
            <button type="button" class="btn-secondary" onclick="document.getElementById(<%= m.to_json %>).close()">Cancel</button>
            <button type="submit" class="btn-primary">Mark as Fulfilled</button>
          </div>
        </form>
      </dialog>
    <% end %>

    <% if @order.awaiting_periodical_fulfillment? && @order.shop_item.type == "ShopItem::LetterMail" && (current_user.admin? || current_user.fulfillment_person?) %>
      <form method="post" action="<%= send_to_theseus_admin_shop_order_path(@order) %>" style="display: inline;">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="admin-btn admin-btn--primary" onclick="return confirm('Send this order to Theseus?')">Send to Theseus</button>
      </form>
      <% if @theseus_sibling_orders&.any? %>
        <form method="post" action="<%= send_to_theseus_admin_shop_order_path(@order) %>" style="display: inline;">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <% @theseus_sibling_orders.each do |sibling| %>
            <%= hidden_field_tag "order_ids[]", sibling.id %>
          <% end %>
          <button type="submit" class="admin-btn admin-btn--primary" onclick="return confirm(<%= "Send #{@theseus_sibling_orders.size + 1} orders to Theseus as one letter?".to_json %>)">Send all to Theseus (<%= @theseus_sibling_orders.size + 1 %> orders)</button>
        </form>
      <% end %>
    <% end %>

    <% if @order.awaiting_periodical_fulfillment? && (current_user.admin? || current_user.fulfillment_person?) %>
      <% m = 'fulfillment-modal' %>
      <button type="button" class="admin-btn admin-btn--primary" onclick="document.getElementById(<%= m.to_json %>).showModal()">Mark as Fulfilled</button>
      <dialog id="<%= m %>" class="fulfill-dialog">
        <h3>Mark order fulfilled</h3>
        <form method="post" action="<%= mark_fulfilled_admin_shop_order_path(@order) %>">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <label>Spent (USD)<input type="number" name="fulfillment_cost" step="0.01" min="0" placeholder="0.00" autocomplete="off"></label>
          <label>Order #<input type="text" name="external_ref" placeholder="e.g. ORD-12345" autocomplete="off"></label>
          <div class="fulfill-actions">
            <button type="button" class="btn-secondary" onclick="document.getElementById(<%= m.to_json %>).close()">Cancel</button>
            <button type="submit" class="btn-primary">Mark as Fulfilled</button>
          </div>
        </form>
      </dialog>
    <% end %>

    <% if @order.on_hold? %>
      <form method="post" action="<%= release_from_hold_admin_shop_order_path(@order) %>">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :return_view, params[:return_view] if params[:return_view].present? %>
        <%= hidden_field_tag :return_status, params[:return_status] if params[:return_status].present? %>
        <button type="submit" class="admin-btn admin-btn--primary" onclick="return confirm('Release this order from hold?')">▶ Release</button>
      </form>
    <% end %>
    <% end %>
  </div>
</div>

<div class="admin-section<%= ' admin-section--highlighted' if @order.internal_notes.present? %>">
  <h2 class="admin-section__header">📝 Internal Notes</h2>
  <p class="admin-section__note">⚠️ Shared between fraud, fulfilment, and admins. Changes are audit logged.</p>
  <% if @order.internal_notes.present? %>
    <div class="admin-alert admin-alert--warning">
      <strong>Note:</strong> <%= simple_format(@order.internal_notes, {}, wrapper_tag: "span") %>
    </div>
  <% end %>
  <form method="post" action="<%= update_internal_notes_admin_shop_order_path(@order) %>">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <textarea name="internal_notes" rows="3" class="admin-textarea" placeholder="Add internal notes about this order..."><%= @order.internal_notes %></textarea>
    <button type="submit" class="btn-primary slim">Save Notes</button>
  </form>
</div>

<%= render Admin::PastOrdersComponent.new(user: @order.user, orders: @user_orders) %>

<%= render "admin/shared/audit_log", record: @order, item_type: "ShopOrder" %>

