<% content_for :title, "Voting Dashboard" %>
<%= render HeadingComponent.new(title: "Voting Dashboard", tone: :blue, size: :full) %>

<div class="voting-grid">
    <div class="card voting-card voting-card--wide">
        <h2>📊 Overview</h2>
        <div class="voting-stats">
        <div class="voting-stat">
            <span class="voting-stat__value"><%= number_with_delimiter(@overview[:legitimate_total]) %><span class="voting-stat__sublabel">/<%= number_with_delimiter(@overview[:total]) %> total</span></span>
            <span class="voting-stat__label">Total Votes</span>
        </div>
        <div class="voting-stat voting-stat--info">
            <span class="voting-stat__value"><%= @overview[:legitimate_today] %><span class="voting-stat__sublabel">/<%= @overview[:today] %> total</span></span>
            <span class="voting-stat__label">Today</span>
        </div>
        <div class="voting-stat voting-stat--success">
            <span class="voting-stat__value"><%= @overview[:legitimate_this_week] %><span class="voting-stat__sublabel">/<%= @overview[:this_week] %> total</span></span>
            <span class="voting-stat__label">This Week</span>
        </div>
        <div class="voting-stat">
            <span class="voting-stat__value"><%= @overview[:avg_time_seconds] ? "#{@overview[:avg_time_seconds]}s" : "—" %></span>
            <span class="voting-stat__label">Avg Time</span>
        </div>
        <div class="voting-stat voting-stat--success">
            <span class="voting-stat__value"><%= number_with_delimiter(@overview[:paid_ships]) %></span>
            <span class="voting-stat__label">Paid Ships</span>
        </div>
        <div class="voting-stat voting-stat--warning">
            <span class="voting-stat__value"><%= number_with_delimiter(@overview[:unpaid_ships]) %></span>
            <span class="voting-stat__label">Unpaid Ships</span>
        </div>
        <div class="voting-stat voting-stat--info">
            <span class="voting-stat__value"><%= number_with_delimiter(@overview[:unpaid_ships_without_bugs]) %></span>
            <span class="voting-stat__label">Unpaid (no bugs)</span>
        </div>
        <div class="voting-stat voting-stat--error">
            <span class="voting-stat__value"><%= number_with_delimiter(@overview[:unpaid_ships_negative_balance]) %></span>
            <span class="voting-stat__label">Unpaid (neg. balance)</span>
        </div>
        </div>
    </div>

    <div class="card voting-card">
        <h2>Engagement</h2>
        <div class="voting-stats">
        <div class="voting-stat voting-stat--info">
            <span class="voting-stat__value"><%= @overview[:demo_click_rate] %>%</span>
            <span class="voting-stat__label">Demo Clicks</span>
        </div>
        <div class="voting-stat voting-stat--purple">
            <span class="voting-stat__value"><%= @overview[:repo_click_rate] %>%</span>
            <span class="voting-stat__label">Repo Clicks</span>
        </div>
        <div class="voting-stat voting-stat--success">
            <span class="voting-stat__value"><%= @overview[:reason_rate] %>%</span>
            <span class="voting-stat__label">With Reason</span>
        </div>
        </div>
    </div>
</div>

<div class="voting-grid">
    <div class="card voting-card voting-card--wide">
        <h2>Suspicious Vote Detection <span id="sus-votes-tooltip" style="cursor: pointer;">ⓘ</span></h2>
        <div class="voting-stats">
        <div class="voting-stat voting-stat--error">
            <span class="voting-stat__value"><%= number_with_delimiter(@suspicious_stats[:total_suspicious]) %></span>
            <span class="voting-stat__label">Total</span>
        </div>
        <div class="voting-stat voting-stat--warning">
            <span class="voting-stat__value"><%= @suspicious_stats[:suspicious_percentage] %>%</span>
            <span class="voting-stat__label">Percentage</span>
        </div>
        <div class="voting-stat voting-stat--error">
            <span class="voting-stat__value"><%= @suspicious_stats[:suspicious_this_week] %></span>
            <span class="voting-stat__label">This Week</span>
        </div>
        </div>
    </div>
    <%= render TooltipComponent.new(target_id: "sus-votes-tooltip", position: :top) do %>
        <strong>Suspicious Votes</strong>
        Votes completed in under <%= Secrets::VoteSuspicion.threshold_seconds %>s are automatically flagged as suspicious and excluded from payout calculations.
    <% end %>
</div>

<div class="voting-grid">
    <div class="card voting-card voting-card--wide">
        <h2>⏱️ Time to Vote Distribution</h2>
        <%= bar_chart @time_distribution, suffix: " votes", colors: ["#6366f1"] %>
    </div>
</div>

<div class="voting-grid">
    <% Vote.enabled_categories.each do |category| %>
        <div class="card voting-card">
        <h2><%= category.to_s.humanize %></h2>
        <div class="category-stats">
            <div class="category-avg">
            <span class="category-avg__value"><%= @category_stats[category][:avg] || "—" %></span>
            <span class="category-avg__label">Average</span>
            </div>
            <%= column_chart @category_stats[category][:distribution], suffix: " votes", min: 0, colors: ["#6366f1"] %>
        </div>
        </div>
    <% end %>
</div>

<div class="voting-grid">
    <div class="card voting-card voting-card--wide">
        <h2>📈 Daily Votes (30 days)</h2>
        <%= line_chart [{ name: "Legitimate", data: @daily_votes }, { name: "Suspicious", data: @daily_suspicious_votes }], min: 0 %>
    </div>
</div>

<div class="voting-grid">
    <div class="card voting-card">
        <h2>Votes by Hour (UTC)</h2>
        <%= bar_chart @hourly_distribution, suffix: " votes", min: 0, colors: ["#6366f1"] %>
    </div>

    <div class="card voting-card">
        <h2>Votes by Day</h2>
        <%= bar_chart @weekly_distribution, suffix: " votes", min: 0, colors: ["#6366f1"] %>
    </div>
</div>

<div class="voting-grid">
    <div class="card voting-card">
        <h2>🏆 Top Voters</h2>
        <table class="voting-table">
        <thead>
            <tr>
            <th>#</th>
            <th>User</th>
            <th>Votes</th>
            </tr>
        </thead>
        <tbody>
            <% @top_voters.each_with_index do |user, index| %>
            <tr>
                <td class="rank">
                <%= index + 1 %>
                </td>
                <td><%= link_to user.display_name || "User ##{user.id}", admin_user_path(user) %></td>
                <td><strong><%= number_with_delimiter(user.votes_count) %></strong></td>
            </tr>
            <% end %>
        </tbody>
        </table>
    </div>

    <div class="card voting-card">
        <h2>🎯 Most Voted Projects</h2>
        <table class="voting-table">
        <thead>
            <tr>
            <th>#</th>
            <th>Project</th>
            <th>Votes</th>
            </tr>
        </thead>
        <tbody>
            <% @most_voted_projects.each_with_index do |project, index| %>
            <tr>
                <td class="rank">
                <%= index + 1 %>
                </td>
                <td><%= link_to truncate(project.title, length: 30), admin_project_path(project) %></td>
                <td><strong><%= project.votes_count %></strong></td>
            </tr>
            <% end %>
        </tbody>
        </table>
    </div>
    </div>

    <div class="voting-grid">
    <div class="card voting-card voting-card--full">
        <h2>Recent Votes</h2>
        <table class="voting-table voting-table--wide">
        <thead>
            <tr>
            <th>Time</th>
            <th>Voter</th>
            <th>Project</th>
            <th>Orig.</th>
            <th>Tech.</th>
            <th>Usab.</th>
            <th>Story.</th>
            <th>Time</th>
            <th>Demo</th>
            <th>Repo</th>
            <th>Sus.</th>
            </tr>
        </thead>
        <tbody>
            <% @recent_votes.each do |vote| %>
            <tr class="<%= 'voting-row--suspicious' if vote.suspicious? %>">
                <td><%= time_ago_in_words(vote.created_at) %> ago</td>
                <td>
                <% if vote.user %>
                    <%= link_to vote.user.display_name || "User ##{vote.user.id}", admin_user_path(vote.user) %>
                <% else %>
                    <span class="text-muted">Unknown</span>
                <% end %>
                </td>
                <td>
                <% if vote.project %>
                    <%= link_to truncate(vote.project.title, length: 20), admin_project_path(vote.project) %>
                <% else %>
                    <span class="text-muted">Deleted</span>
                <% end %>
                </td>
                <td class="score"><%= vote.originality_score || "—" %></td>
                <td class="score"><%= vote.technical_score || "—" %></td>
                <td class="score"><%= vote.usability_score || "—" %></td>
                <td class="score"><%= vote.storytelling_score || "—" %></td>
                <td><%= vote.time_taken_to_vote ? "#{vote.time_taken_to_vote}s" : "—" %></td>
                <td><%= vote.demo_url_clicked ? "✓" : "—" %></td>
                <td><%= vote.repo_url_clicked ? "✓" : "—" %></td>
                <td><%= vote.suspicious? ? "⚠️" : "—" %></td>
            </tr>
            <% end %>
        </tbody>
        </table>
    </div>
</div>

<%= link_to "← Back", admin_root_path, class: "btn-secondary" %>
