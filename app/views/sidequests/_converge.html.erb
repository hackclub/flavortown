<%= link_to sidequest_path(sidequest), id: "converge", class: "sidequest-card sidequest-card--converge sidequest-card--link" do %>
  <div class="sidequest-card__content">
    <div class="sidequest-card__converge-message">
      <%= image_tag "https://cdn.mahadk.com/s/v3/ab7c183beb51aa7d_image.png", class: "sidequest-card__converge-avatar", alt: "ConvergeBot" %>
      <div class="sidequest-card__converge-body">
        <div class="sidequest-card__converge-msg-header">
          <span class="sidequest-card__converge-author">ConvergeBot</span>
          <span class="sidequest-card__converge-app-badge">APP</span>
        </div>
        <p class="sidequest-card__converge-text"><strong>Converge</strong> - build a Slack or Discord bot and ship it! Create something that lives where you and your friends hang out.</p>
        <div class="sidequest-card__converge-meta">
          <% if sidequest.approved_count > 0 %>
            <span class="sidequest-card__converge-badge"><%= pluralize(sidequest.approved_count, "submission") %></span>
          <% end %>
          <% if sidequest.expires_at.present? %>
            <span class="sidequest-card__converge-badge"><%= sidequest.expired? ? "Ended" : "Ends" %> <%= sidequest.expires_at.strftime("%B %d, %Y") %></span>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>
