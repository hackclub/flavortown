<% content_for :title, @sidequest.title %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>

<%= render HeadingComponent.new(title: @sidequest.title, tone: :blue, size: :full) %>

<div class="sidequest-show sidequest-show--optimization">
  <div class="sidequest-show__content">
    <% if @sidequest.description.present? %>
      <p class="sidequest-show__description"><%= @sidequest.description %></p>
    <% end %>

    <div class="sidequest-show__info-grid">
      <section class="sidequest-show__info-card">
        <h3 class="sidequest-show__info-title">Requirements</h3>
        <ul class="sidequest-show__steps">
          <li>Build an arcade classic retro game.</li>
          <li>Don't just copy the game, Add your own twist to it!</li>
          <li>It can be a web app, itch.io playable, desktop app, CLI or anything that can have a demo!</li>
          <li>Add a short README section that explains all the game features and the keybinds.</li>
          <li>Ship it on Flavortown and submit it to this sidequest when shipping!.</li>
        </ul>
      </section>

      <section class="sidequest-show__info-card">
        <h3 class="sidequest-show__info-title">Game Ideas</h3>
        <p class="sidequest-show__help-note">Tetris</p>
        <p class="sidequest-show__help-note">Snake</p>
        <p class="sidequest-show__help-note">Pong</p>
        <p class="sidequest-show__help-note">Pac-Man</p>
        <p class="sidequest-show__help-note">Space Invaders</p>
      </section>
    </div>

    <% if @approved_entries.any? %>
      <div class="sidequest-show__gallery">
        <h3 class="sidequest-show__gallery-title"><%= @approved_entries.size %> <%= "submission".pluralize(@approved_entries.size) %></h3>
        <div class="sidequest-show__gallery-grid">
          <% @approved_entries.each do |entry| %>
            <% project = entry.project %>
            <% next unless project.present? %>
            <div class="sidequest-show__gallery-item">
              <%= render partial: "projects/card", locals: { project: project } %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="sidequest-show__stats">
        <p><strong>Be the first to submit</strong></p>
      </div>
    <% end %>

    <div class="sidequest-show__actions">
      <%= render ButtonComponent.new(
        text: "Back to Sidequests",
        href: sidequests_path,
        color: :brown,
        variant: :borderless
      ) %>
    </div>
  </div>
</div>

<script>
    (() => {
        const canvas = document.getElementById("physics-lab-canvas");
        if (!canvas) return;

        const context = canvas.getContext("2d");
        const gravityInput = document.getElementById("physics-lab-gravity");
        const gravityValue = document.getElementById("physics-lab-gravity-value");
        const balls = [];

        function spawnBall(x, y) {
            balls.push({
                x,
                y,
                vx: (Math.random() - 0.5) * 6,
                vy: -4 - Math.random() * 4,
                r: 6 + Math.random() * 6
            });
        }

        canvas.addEventListener("click", (event) => {
            const rect = canvas.getBoundingClientRect();
            const x = ((event.clientX - rect.left) / rect.width) * canvas.width;
            const y = ((event.clientY - rect.top) / rect.height) * canvas.height;
            for (let i = 0; i < 8; i += 1) spawnBall(x, y);
        });

        gravityInput.addEventListener("input", () => {
            gravityValue.textContent = Number(gravityInput.value).toFixed(2);
        });

        function draw() {
            context.fillStyle = "#f8f1e3";
            context.fillRect(0, 0, canvas.width, canvas.height);

            context.fillStyle = "#d9b38c";
            context.fillRect(0, canvas.height - 24, canvas.width, 24);

            const gravity = Number(gravityInput.value);

            balls.forEach((ball) => {
                ball.vy += gravity * 0.08;
                ball.x += ball.vx;
                ball.y += ball.vy;

                if (ball.x < ball.r || ball.x > canvas.width - ball.r) ball.vx *= -0.9;
                if (ball.y > canvas.height - 24 - ball.r) {
                    ball.y = canvas.height - 24 - ball.r;
                    ball.vy *= -0.78;
                    ball.vx *= 0.98;
                }

                context.beginPath();
                context.fillStyle = "#4a90e2";
                context.arc(ball.x, ball.y, ball.r, 0, Math.PI * 2);
                context.fill();
            });

            while (balls.length > 120) balls.shift();
            requestAnimationFrame(draw);
        }

        gravityValue.textContent = Number(gravityInput.value).toFixed(2);
        for (let i = 0; i < 18; i += 1) spawnBall(100 + i * 26, 52 + Math.random() * 80);
        requestAnimationFrame(draw);
    })();
</script>
