<% content_for :title, @sidequest.title %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>

<%= render HeadingComponent.new(
      title: @sidequest.title,
      tone: :blue,
      size: :full
    ) %>

<div class="sidequest-show sidequest-show--kernel">
  <%= tag.div class: "kernel-pattern-overlay", style: "background-image: url('#{asset_path('mask/pattern.png')}');" %>
  <div class="sidequest-show__content">
    <p>Build a project that runs entirely in the terminal. Submit it to this sidequest to qualify for kernel prizes in the shop.</p>

    <div class="sidequest-show__info-grid">
      <section class="sidequest-show__info-card">
        <h3 class="sidequest-show__info-title">Requirements</h3>
        <ul class="sidequest-show__steps">
          <li>
            <strong>Must run in the terminal (CLI / TUI / GUI)</strong>.
          </li>
          <li>
            <strong>web UI are allowed (basic ASCII / TUI libraries are nice)</strong>.
          </li>
          <li>
            <strong>Include clear setup and run instructions in README</strong>.
          </li>
          <li>
            <strong>should be interactive and provide meaningful utility</strong>.
          </li>
          <li>
            <strong>great UX (keyboard shortcuts, clean output, helpful commands)</strong>.
          </li>
        </ul>
        <p class="sidequest-show__help-note">
          Your project must be public on GitHub.
        </p>
        <p class="sidequest-show__help-note">
          If you have any other questions, feel free to DM <%= link_to "@nok",
          "https://hackclub.enterprise.slack.com/archives/D0A1NMESB41", target:
          "_blank", rel: "noopener", class: "kernel-contact-link" %> on Slack.
        </p>
      </section>

      <section class="sidequest-show__info-card">
        <h3 class="sidequest-show__info-title">Submission checklist</h3>
        <ul class="sidequest-show__steps">
          <li>Public GitHub repo with source and a release/demo.</li>
          <li>Clear README with setup & command instructions.</li>
          <li>Runnable demo or downloadable artifact.</li>
          <li>Ship on Flavortown and submit to this sidequest.</li>
        </ul>
        <p class="sidequest-show__help-note">
          Make it interesting, do you want to use it?
        </p>
      </section>
    </div>

    <div class="sidequest-show__info-grid">
      <section class="sidequest-show__info-card">
        <h3 class="sidequest-show__info-title">Allowed project types</h3>
        <ul class="sidequest-show__steps">
          <li>Traditional CLI tools</li>
          <li>Web terminal simulations</li>
          <li>Desktop terminal apps</li>
          <li>Terminal games</li>
          <li>Dashboards or utilities</li>
        </ul>
      </section>
    </div>

    <% if @prizes.present? && @prizes.any? %>
    <section class="sidequest-show__info-card sidequest-show__prizes-card">
      <h3 class="sidequest-show__info-title">Prizes to unlock</h3>
      <div class="sidequest-show__prizes-list">
        <% @prizes.each do |prize| %>
        <div class="sidequest-show__prize-row" role="listitem">
          <% if prize.image.attached? %>
            <div class="sidequest-show__prize-image">
              <%= image_tag prize.image.variant(:carousel_sm), alt: prize.name, loading: "lazy" %>
            </div>
          <% end %>
          <span class="sidequest-show__prize-name"><%= prize.name %></span>
        </div>
        <% end %>
      </div>
    </section>
    <% end %>
    <% if @approved_entries.any? %>
    <div class="sidequest-show__gallery">
      <h3 class="sidequest-show__gallery-title">
        <%= @approved_entries.size %>
        <%= "submission".pluralize(@approved_entries.size) %>
      </h3>
      <div class="sidequest-show__gallery-grid">
        <% @approved_entries.each do |entry| %>
          <% project = entry.project %>
          <% next unless project.present? %>
        <div class="sidequest-show__gallery-item">
          <%= render partial: "projects/card", locals: { project: project } %>
        </div>
        <% end %>
      </div>
    </div>
    <% else %>
    <div class="sidequest-show__stats">
      <p><strong>Be the first to submit</strong></p>
    </div>
    <% end %>
  </div>
</div>
