<%= link_to sidequest_path(sidequest), id: "lockin", class: "sidequest-card sidequest-card--lockin sidequest-card--link" do %>
  <div class="sidequest-card__content">
    <%= image_tag "https://www.obayy.dev/images/lockin.png",
                  alt: "",
                  aria: { hidden: true },
                  class: "sidequest-card__image" %>
    <h1 class="sidequest-card__title">Lock in</h1>
    <h2>Work 10 hrs a week for 4 weeks without missing an hour. Unlock 120 cookies & amazing prizes.</h2>
    <% if sidequest.approved_count > 0 %>
      <p class="sidequest-card__expires"><%= pluralize(sidequest.approved_count, "submission") %></p>
    <% end %>
    <% if sidequest.expires_at.present? %>
      <p class="sidequest-card__expires"><%= sidequest.expired? ? "Ended" : "Ends" %> <%= sidequest.expires_at.strftime("%B %d, %Y") %></p>
    <% end %>
  </div>
<% end %>
