<%= link_to sidequest_path(sidequest), id: "optimization", class: "sidequest-card sidequest-card--link" do %>
  <div class="sidequest-card__content">
    <%= image_tag "launch/optimize-orpheus.png",
                  alt: "",
                  aria: { hidden: true },
                  class: "sidequest-card__image" %>
    <h1 class="sidequest-card__title">Optimization</h1>
    <h2>Build a project optimized for speed, memory, or size. Show how you kept it efficient in your README. Submit it to this sidequest to qualify for optimization prizes (RAM/Storage) in the shop.</h2>
    <% if sidequest.approved_count > 0 %>
      <p class="sidequest-card__expires"><%= pluralize(sidequest.approved_count, "submission") %></p>
    <% end %>
    <% if sidequest.expires_at.present? %>
      <p class="sidequest-card__expires"><%= sidequest.expired? ? "Ended" : "Ends" %> <%= sidequest.expires_at.strftime("%B %d, %Y") %></p>
    <% end %>
  </div>
<% end %>
