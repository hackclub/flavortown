<%= link_to sidequest_path(sidequest), id: "haunted", class: "haunted-card-link" do %>
  <div class="haunted-card">
    <div class="haunted-card__image-wrap">
      <%= image_tag "sidequests/haunted.png",
        alt: "",
        aria: { hidden: true },
        class: "haunted-card__image" %>
    </div>

    <h1 class="haunted-card__title">HAUNTED</h1>
  </div>
<% end %>

<style>
  .haunted-card-link {
    display: block;
    text-decoration: none;
  }

  .haunted-card {
    position: relative;
    overflow: hidden;
    max-width: 503px;
    margin: 0 auto;
    border-radius: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: #000000;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: 0 18px 50px rgba(0, 0, 0, 0.35);
    padding: 1rem;
    transition: transform 140ms ease, box-shadow 140ms ease, border-color 140ms ease;
  }

  .haunted-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      repeating-linear-gradient(
        to bottom,
        rgba(255, 255, 255, 0.05),
        rgba(255, 255, 255, 0.05) 1px,
        transparent 2px,
        transparent 4px
      );
    opacity: 0.18;
    mix-blend-mode: screen;
  }

  .haunted-card__image-wrap {
    overflow: hidden;
    border-radius: 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.25);
  }

  .haunted-card__image {
    display: block;
    width: 100%;
    height: auto;
    transform: scale(1.01);
    transition: transform 180ms ease, filter 180ms ease;
    filter: brightness(0.92) contrast(1.08);
  }

  .haunted-card__title {
    margin: 0.85rem 0 0;
    text-align: center;
    color: #f4f1ff;
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-indent: 0.2em;
  }

  .haunted-card:hover {
    border-color: rgba(180, 120, 255, 0.35);
    box-shadow: 0 22px 70px rgba(0, 0, 0, 0.52);
    animation: haunted-shake 0.18s infinite linear;
  }

  .haunted-card:hover .haunted-card__image {
    transform: scale(1.05);
    filter: brightness(1) contrast(1.15);
  }

  .haunted-card:hover .haunted-card__title {
    animation:
      haunted-flicker 0.14s infinite steps(2, end),
      haunted-title-jitter 0.55s infinite steps(2, end);
  }

  @keyframes haunted-shake {
    0%   { transform: translate(0, 0) rotate(0deg); }
    20%  { transform: translate(-2px, 1px) rotate(-0.4deg); }
    40%  { transform: translate(2px, -1px) rotate(0.4deg); }
    60%  { transform: translate(-3px, 2px) rotate(-0.7deg); }
    80%  { transform: translate(3px, -2px) rotate(0.7deg); }
    100% { transform: translate(0, 0) rotate(0deg); }
  }

  @keyframes haunted-flicker {
    0%, 100% { opacity: 1; filter: brightness(1); }
    25% { opacity: 0.2; filter: brightness(1.7); }
    50% { opacity: 0.95; filter: brightness(0.85); }
    75% { opacity: 0.05; filter: brightness(2); }
  }

  @keyframes haunted-title-jitter {
    0% { transform: translate(0, 0); }
    20% { transform: translate(-1px, 1px); }
    40% { transform: translate(2px, -1px); }
    60% { transform: translate(-2px, 0); }
    80% { transform: translate(1px, 2px); }
    100% { transform: translate(0, 0); }
  }
</style>
