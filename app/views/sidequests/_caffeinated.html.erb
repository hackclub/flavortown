<%= link_to sidequest_path(sidequest), id: "caffeinated", class: "sidequest-card sidequest-card--orange sidequest-card--link" do %>
  <div class="sidequest-card__content">
    <%= image_tag "launch/caffeinated-main-logo.png",
                  alt: "",
                  aria: { hidden: true },
                  class: "sidequest-card__image" %>
    <h1 class="sidequest-card__title">Caffeinated</h1>
    <h2>
      Ship a project that helps people stay awake, focused, or productive.
      Unlock caffeinated prizes in the shop!
    </h2>
    <% if sidequest.approved_count > 0 %>
      <p class="sidequest-card__expires"><%= pluralize(sidequest.approved_count, "submission") %></p>
    <% end %>
    <% if sidequest.expires_at.present? %>
      <p class="sidequest-card__expires"><%= sidequest.expired? ? "Ended" : "Ends" %> <%= sidequest.expires_at.strftime("%B %d, %Y") %></p>
    <% end %>
  </div>
<% end %>
