<% content_for :title, @sidequest.title %>
<% content_for :og_description, truncate(@sidequest.description.to_s, length: 200) %>
<% content_for :og_image, og_image_url('sidequests', format: :png) %>
<% content_for :twitter_card, "summary_large_image" %>

<style>
  body {
    background-color: #0a0a0a !important;
    color: #f5f5f5 !important;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    background: rgba(10, 10, 10, 0.55);
    pointer-events: none;
    z-index: 0;
  }

  body > * {
    position: relative;
  }

  nav,
  aside,
  [role="navigation"] {
    filter: none;
  }

  nav :not(.sidebar__user),
  aside :not(.sidebar__user),
  [role="navigation"] :not(.sidebar__user) {
    filter: grayscale(1) contrast(1.15);
  }

  .sidebar__user,
  .sidebar__user-card,
  .sidebar__user-avatar,
  .sidebar__user-details,
  .sidebar__user-actions,
  .sidebar__user-name,
  .sidebar__user-balance,
  .sidebar__user-settings,
  .sidebar__user-logout {
    filter: none !important;
    color: inherit !important;
    background-color: inherit !important;
    border-color: inherit !important;
  }

  .sidebar__user * {
    filter: none !important;
    color: inherit !important;
    background-color: inherit !important;
    border-color: inherit !important;
  }

  main,
  .container,
  .haunted-page {
    filter: grayscale(1) contrast(1.15);
  }

  :is(header, nav, main, aside, section, article, footer) {
    background-color: transparent !important;
    color: #f5f5f5 !important;
  }

  :is(a, button, input, select, textarea, [role="button"], .btn, .button) {
    color: #f5f5f5 !important;
    border-color: rgba(255, 255, 255, 0.2) !important;
    background-color: rgba(30, 30, 30, 0.8) !important;
  }

  :is(.sidequest-card, .sidequest-card__content, .sidequest-card__title, .sidequest-card__expires, .sidequest-card__image-container) {
    background-color: rgba(20, 20, 20, 0.7) !important;
    color: #f5f5f5 !important;
    border-color: rgba(255, 255, 255, 0.15) !important;
  }

  .haunted-page {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: transparent;
    color: #f5f5f5;
  }

  .haunted-page::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: transparent;
    z-index: 5;
    opacity: 0;
  }

  .haunted-page::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    box-shadow: none;
    z-index: 6;
  }

  .haunted-wrap {
    position: relative;
    z-index: 10;
    min-height: 100%;
    padding: 2rem 0 3rem;
  }

  .haunted-flash-layer {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 7;
    overflow: hidden;
  }

  .haunted-flash {
    position: absolute;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.85);
    filter: blur(2px);
    animation: haunted-flash-pop 240ms ease-out forwards;
  }

  @keyframes haunted-flash-pop {
    0% {
      transform: scale(0.25);
      opacity: 0.95;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  .haunted-hero {
    min-height: 42vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem 1rem 1rem;
  }

  .haunted-title-wrap {
    display: inline-block;
    position: relative;
    isolation: isolate;
  }

  .haunted-title {
    position: relative;
    margin: 0;
    color: #fff;
    font-size: clamp(3.4rem, 8vw, 7rem);
    line-height: 0.9;
    letter-spacing: 0.03em;
    text-shadow: 0 0 22px rgba(255, 255, 255, 0.12);
    animation:
      haunted-title-blink 2.1s infinite,
      haunted-title-shake 0.28s infinite steps(2, end);
  }

  @keyframes haunted-title-blink {
    0%, 100% { opacity: 1; filter: brightness(1) contrast(1); }
    8% { opacity: 0.85; }
    10% { opacity: 0.22; }
    12% { opacity: 1; }
    27% { opacity: 0.95; }
    29% { opacity: 0.35; }
    31% { opacity: 1; }
    63% { opacity: 0.9; }
    65% { opacity: 0.15; }
    67% { opacity: 1; }
  }

  @keyframes haunted-title-shake {
    0% { transform: translate(0, 0); }
    20% { transform: translate(-1px, 1px); }
    40% { transform: translate(2px, -1px); }
    60% { transform: translate(-2px, 0); }
    80% { transform: translate(1px, 2px); }
    100% { transform: translate(0, 0); }
  }

  .haunted-subtitle {
    max-width: 52rem;
    margin: 1rem auto 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.8;
    text-shadow: 0 0 18px rgba(0, 0, 0, 0.35);
  }

  .haunted-section {
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto 1.75rem;
    padding: 1.25rem;
    border-radius: 1.6rem;
    border: none;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }

  .haunted-section--tab {
    padding: 0.9rem;
  }

  .haunted-section-title {
    margin: 0 0 0.95rem;
    color: #f5f5f5;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.08);
  }

  .haunted-note {
    margin-top: -0.35rem;
    margin-bottom: 1rem;
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.9rem;
  }

  .haunted-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .haunted-slot {
    min-height: 9.5rem;
    padding: 1rem;
    border-radius: 1.15rem;
    border: none;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }

  .rgb-text {
    color: #f8f8f8;
    text-shadow:
      1px 0 0 rgba(255, 255, 255, 0.5),
      -1px 0 0 rgba(255, 255, 255, 0.25),
      0 1px 0 rgba(255, 255, 255, 0.15);
    animation: rgb-shift 1.7s linear infinite;
  }

  @keyframes rgb-shift {
    0% {
      text-shadow:
        1px 0 0 rgba(255, 255, 255, 0.5),
        -1px 0 0 rgba(255, 255, 255, 0.25),
        0 1px 0 rgba(255, 255, 255, 0.15);
    }
    25% {
      text-shadow:
        0 1px 0 rgba(255, 255, 255, 0.5),
        1px 0 0 rgba(255, 255, 255, 0.25),
        -1px -1px 0 rgba(255, 255, 255, 0.15);
    }
    50% {
      text-shadow:
        -1px 0 0 rgba(255, 255, 255, 0.5),
        1px 1px 0 rgba(255, 255, 255, 0.25),
        0 -1px 0 rgba(255, 255, 255, 0.15);
    }
    75% {
      text-shadow:
        1px 1px 0 rgba(255, 255, 255, 0.5),
        0 -1px 0 rgba(255, 255, 255, 0.25),
        -1px 0 0 rgba(255, 255, 255, 0.15);
    }
    100% {
      text-shadow:
        1px 0 0 rgba(255, 255, 255, 0.5),
        -1px 0 0 rgba(255, 255, 255, 0.25),
        0 1px 0 rgba(255, 255, 255, 0.15);
    }
  }

  .haunted-label {
    display: block;
    margin-bottom: 0.4rem;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.85rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .haunted-placeholder {
    min-height: 4.7rem;
    color: rgba(255, 255, 255, 0.88);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .haunted-faq-item {
    padding: 1rem 1rem 1.1rem;
    border-radius: 1.2rem;
    border: none;
    background: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .haunted-faq-q {
    margin: 0;
    color: #ffffff;
    font-size: 1.02rem;
    font-weight: 800;
  }

  .haunted-faq-a {
    margin-top: 0.55rem;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.75;
  }

  .haunted-reward {
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
  }

  .haunted-reward-header {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    width: 500%;
  }

  .haunted-box-link {
    display: block;
    width: min(520px, 100%);
    transition: transform 180ms ease, filter 180ms ease;
    filter: drop-shadow(0 16px 28px rgba(0, 0, 0, 0.48));
  }

  .haunted-box-link:hover {
    transform: translateY(-2px) scale(1.01);
    filter: drop-shadow(0 22px 34px rgba(0, 0, 0, 0.58));
  }

  .haunted-box-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 1rem;
  }

  .haunted-mystery-subtitle {
    margin-top: 1.5rem;
    color: #ffffff;
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.6;
    text-shadow: 
      0 0 10px rgba(255, 255, 255, 0.6),
      0 0 20px rgba(255, 255, 255, 0.4),
      0 0 30px rgba(255, 255, 255, 0.2);
  }

  .haunted-back {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.9rem 1.2rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(15, 15, 15, 0.75);
    color: rgba(255, 255, 255, 0.9);
    text-decoration: none;
    transition: transform 160ms ease, background 160ms ease;
  }

  .haunted-back:hover {
    transform: translateY(-1px);
    background: rgba(25, 25, 25, 0.85);
  }

  .sidequest-show__gallery {
    width: min(1120px, calc(100% - 2rem));
    margin: 1.75rem auto;
    padding: 1.25rem;
    border-radius: 1.6rem;
    background: transparent;
  }

  .sidequest-show__gallery-title {
    margin: 0 0 1rem;
    color: #f5f5f5;
    font-size: 1.05rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.08);
  }

  .sidequest-show__gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .sidequest-show__gallery-item {
    border-radius: 1.15rem;
    overflow: hidden;
    filter: grayscale(1) contrast(1.15);
    transition: transform 180ms ease, filter 180ms ease;
  }

  .sidequest-show__gallery-item:hover {
    transform: translateY(-4px);
    filter: grayscale(0.85) contrast(1.2) brightness(1.05);
  }

  .sidequest-show__stats {
    width: min(1120px, calc(100% - 2rem));
    margin: 1.75rem auto;
    padding: 2rem 1.25rem;
    border-radius: 1.6rem;
    text-align: center;
    background: transparent;
  }

  .sidequest-show__stats p {
    margin: 0;
    color: #f5f5f5;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
    text-shadow: 0 0 14px rgba(255, 255, 255, 0.08);
  }

  .sidequest-show__mystery-box-visual {
    display: flex;
    justify-content: center;
    margin: 0;
    flex-shrink: 0;
  }

  .mystery-box-img {
    max-width: 50px;
    height: auto;
    border-radius: 0.4rem;
    filter: grayscale(0) contrast(1) drop-shadow(0 4px 8px rgba(0, 0, 0, 0.6));
    transition: transform 200ms ease;
  }

  .mystery-box-img:hover {
    transform: scale(1.1);
  }

  @media (max-width: 768px) {
    .haunted-grid {
      grid-template-columns: 1fr;
    }

    .haunted-hero {
      min-height: 34vh;
      padding-top: 1.4rem;
    }

    .haunted-section {
      width: calc(100% - 1rem);
      padding: 1rem;
    }

    .sidequest-show__gallery {
      width: calc(100% - 1rem);
      margin: 1.5rem auto;
    }

    .sidequest-show__gallery-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .sidequest-show__stats {
      width: calc(100% - 1rem);
      padding: 1.5rem 1rem;
    }
  }
</style>

<div class="haunted-page sidequest-show sidequest-show--haunted">
  <div class="haunted-flash-layer" id="haunted-flash-layer"></div>

  <div class="haunted-wrap">
    <section class="haunted-hero">
      <div>
        <div class="haunted-title-wrap">
          <h1 class="haunted-title" data-text="Haunted" id="haunted-title">Haunted</h1>
        </div>

        <p class="haunted-subtitle">
          Build horror or mysterious projects, win a mystery box.
        </p>
      </div>
    </section>

    <section class="haunted-section haunted-section--tab">
      <h2 class="haunted-section-title">Requirements</h2>
      <p class="haunted-note">You must follow these requirements to submit your project successfully!</p>

      <div class="haunted-grid">
        <div class="haunted-slot">
          <span class="haunted-label">Requirement 1</span>
          <div class="haunted-placeholder rgb-text">
            The project MUST be horror/mystery themed. Make sure the theme of your project uses any genre under the "horror-umbrella"(for genre details, pls search it up)
          </div>
        </div>

        <div class="haunted-slot">
          <span class="haunted-label">Requirement 2</span>
          <div class="haunted-placeholder rgb-text">
            It should be a quality submission that shows effort and creativity! The project must be functional and interactive.
          </div>
        </div>
      </div>
    </section>

    <section class="haunted-section">
      <h2 class="haunted-section-title">FAQ</h2>

      <div class="haunted-grid">
        <div class="haunted-faq-item">
          <h3 class="haunted-faq-q">What is this?</h3>
          <p class="haunted-faq-a">
            Haunted is a sidequest for anyone who likes building spooky, eerie, or horror-themed projects. Submit a horror themed project,
            and unlock a Mystery Box from the shop to gamble all your currency away for a chance to win something cool!
          </p>
        </div>

        <div class="haunted-faq-item">
          <h3 class="haunted-faq-q">What counts as a valid project?</h3>
          <p class="haunted-faq-a">
            Any type of project that represents a dark-theme (example: horror, mystery etc..)
            Note: When submitting a project, just select "Haunted" as the sidequest you're submitting to.
          </p>
        </div>

        <div class="haunted-faq-item" style="grid-column: 1 / -1;">
          <h3 class="haunted-faq-q">What is the reward?</h3>
          <p class="haunted-faq-a">
            You get to unlock a Mystery Box from the shop!
          </p>
        </div>
      </div>
    </section>

    <section class="haunted-section haunted-reward">
      <div class="haunted-reward-header">
        <h2 class="haunted-section-title">Your reward: A Mystery Box!</h2>
        <div class="sidequest-show__mystery-box-visual">
          <%= image_tag 'sidequests/haunted-removebg-preview.png', alt: 'Mystery Box', class: 'mystery-box-img' %>
        </div>
      </div>
      <p class="haunted-note">Submit a project to the sidequest to get access to buy one!</p>

      <% if @prizes.present? && @prizes.any? %>
        <section class="sidequest-show__info-card sidequest-show__prizes-card">
          <h3 class="sidequest-show__info-title">Prizes</h3>
          <div class="sidequest-show__prizes-list">
            <% @prizes.each do |prize| %>
              <%= link_to "/shop/order?shop_item_id=#{prize.id}", class: "sidequest-show__prize-row" do %>
                <% if prize.image.attached? %>
                  <div class="sidequest-show__prize-image">
                    <%= image_tag prize.image.variant(:carousel_sm), alt: prize.name, loading: "lazy" %>
                  </div>
                <% end %>
                <span class="sidequest-show__prize-name"><%= prize.name %></span>
                <span class="sidequest-show__prize-cost"><%= number_to_currency(prize.ticket_cost, precision: 0).gsub('$', '') %></span>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>

      <p class="haunted-mystery-subtitle">
        Any persons who purchase a mystery box have the chance to roll anything from a sticker to a *********<br>
        Test your luck out in these last days of flavortown!
      </p>
    </section>

    <% if @approved_entries.any? %>
      <div class="sidequest-show__gallery">
        <h3 class="sidequest-show__gallery-title"><%= @approved_entries.size %> <%= "submission".pluralize(@approved_entries.size) %></h3>
        <div class="sidequest-show__gallery-grid">
          <% @approved_entries.each do |entry| %>
            <% project = entry.project %>
            <% next unless project.present? %>
            <div class="sidequest-show__gallery-item">
              <%= render partial: "projects/card", locals: { project: project } %>
            </div>
          <% end %>
        </div>
      </div>
    <% else %>
      <div class="sidequest-show__stats">
        <p><strong>Be the first to submit</strong></p>
      </div>
    <% end %>

    <audio id="haunted-bgm" preload="auto" loop>
    <source src="<%= asset_path('sidequests/faqmusic.mp3') %>" type="audio/mpeg">
    </audio>

    <div class="pb-12 text-center">
      <%= link_to "Back to Sidequests", sidequests_path, class: "haunted-back" %>
    </div>
  </div>
</div>

<script>
(() => {
  const title = document.getElementById("haunted-title");
  if (title) {
    const cycle = () => {
      const intensity = Math.random();
      title.style.filter = intensity > 0.82 ? "brightness(0.92) contrast(1.14)" : "none";
      title.style.transform = intensity > 0.84
        ? `translate(${(Math.random() * 4 - 2).toFixed(1)}px, ${(Math.random() * 4 - 2).toFixed(1)}px)`
        : "translate(0, 0)";
    };

    setInterval(cycle, 2300);
    cycle();
  }

  const flashLayer = document.getElementById("haunted-flash-layer");
  const spawnFlash = () => {
    if (!flashLayer) return;

    const flash = document.createElement("span");
    const size = 18 + Math.random() * 110;
    flash.className = "haunted-flash";
    flash.style.width = `${size}px`;
    flash.style.height = `${size}px`;
    flash.style.left = `${Math.random() * 100}%`;
    flash.style.top = `${Math.random() * 100}%`;
    flash.style.opacity = `${0.28 + Math.random() * 0.62}`;
    flashLayer.appendChild(flash);

    window.setTimeout(() => flash.remove(), 260);
  };

  window.setInterval(spawnFlash, 420);
  for (let i = 0; i < 4; i += 1) {
    window.setTimeout(spawnFlash, i * 120);
  }

  const bgm = document.getElementById("haunted-bgm");
  if (!bgm) return;
  bgm.volume = 0.1;

  const tryPlay = () => {
    bgm.play().catch(() => {});
  };

  tryPlay();

  const unlockAudio = () => {
    tryPlay();
    window.removeEventListener("click", unlockAudio);
    window.removeEventListener("keydown", unlockAudio);
    window.removeEventListener("touchstart", unlockAudio);
  };

  window.addEventListener("click", unlockAudio, { once: true });
  window.addEventListener("keydown", unlockAudio, { once: true });
  window.addEventListener("touchstart", unlockAudio, { once: true });
})();
</script>
