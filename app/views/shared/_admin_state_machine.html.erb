<% if (current_user&.admin? || current_user&.fraud_dept?) && record.respond_to?(:aasm) %>
  <% current_state = record.aasm.current_state %>
  <% available_events = record.aasm.events(permitted: true) %>

  <div class="state-machine">
    <div class="state-machine__header">State Machine</div>

    <div class="state-machine__row">
      <span class="state-machine__label">Current State:</span>
      <span class="state-machine__current state-machine__current--<%= current_state %>">
        <%= current_state.to_s.humanize %>
      </span>
    </div>

    <% if available_events.any? %>
      <div class="state-machine__row">
        <span class="state-machine__label">Available Transitions:</span>
        <ul class="state-machine__transitions">
          <% available_events.each do |event| %>
            <li class="state-machine__event">
              <strong><%= event.name.to_s.humanize %></strong>
              <% targets = event.transitions.select { |t| t.from == current_state || t.from.include?(current_state) rescue false }.map(&:to).uniq %>
              <% if targets.any? %>
                → <span class="state-machine__target state-machine__current--<%= targets.first %>"><%= targets.map { |t| t.to_s.humanize }.join(", ") %></span>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>
    <% else %>
      <div class="state-machine__row">
        <span class="state-machine__no-transitions">No transitions available from this state</span>
      </div>
    <% end %>

    <% if current_user&.admin? %>
      <%
        all_states = record.aasm.states.map { |s| s.name.to_s }
        force_state_url = begin
          url_for([:force_state, :admin, record])
        rescue ActionController::UrlGenerationError, NoMethodError
          nil
        end
      %>
      <% if force_state_url %>
        <div class="state-machine__row">
          <details>
            <summary class="state-machine__label" style="cursor: pointer;">⚠️ Force Override State</summary>
            <form method="post" action="<%= force_state_url %>" style="display: flex; gap: 0.5rem; align-items: center; margin-top: 0.5rem;">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <%= select_tag :target_state,
                    options_for_select(all_states.map { |s| [s.humanize, s] }, current_state.to_s),
                    class: "form-control", style: "max-width: 200px;" %>
              <button type="submit" class="btn-danger slim" onclick="return confirm('Are you sure? This bypasses all AASM guards and callbacks.')">Force</button>
            </form>
          </details>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
