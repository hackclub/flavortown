<% content_for :title, "Your Wrapped" %>

<%= content_for :stylesheets do %>
  <%= stylesheet_link_tag "wrapped", "data-turbo-track": "reload" %>
<% end %>

<div class="wrapped-page">
  <h1 class="wrapped-page__title">Your Wrapped</h1>

  <div class="wrapped-container"
       data-controller="wrapped"
       data-action="click->wrapped#click"
       data-turbo="false"
       data-wrapped-interval-value="8000"
       data-wrapped-cookies-value="<%= @wrapped.total_cookies_earned %>"
       data-wrapped-ships-value="<%= @wrapped.ships_count %>"
       data-wrapped-devlogs-value="<%= @wrapped.devlogs_count %>"
       data-wrapped-coding-value="<%= @wrapped.coding_hours %>"
       data-wrapped-username-value="<%= current_user.display_name %>"
       data-wrapped-bento-value="<%= @wrapped.bento_payload.to_json %>">

    <% slides = [:intro, :shipping, :payout, :reports, :shop_orders, :shop_orders_list, :voting, :achievements] %>
    <% slides << :sidequests  if @wrapped.sidequests_completed > 0 %>
    <% slides << :support     if @wrapped.support_helper? || (@wrapped.support_stats[:tickets_opened] || 0) > 0 %>
    <% slides << :shipwright  if @wrapped.shipwright_reviewer? %>
    <% slides << :complete %>

    <div class="wrapped-progress">
      <% slides.count.times do %>
        <div class="wrapped-progress-segment empty" data-wrapped-target="segment"></div>
      <% end %>
    </div>

    <% slides.each do |slide| %>
      <% case slide %>
      <% when :intro %>
        <%= render "wrapped/slides/intro", user: current_user %>
      <% when :complete %>
        <%= render "wrapped/slides/complete", user: current_user %>
      <% else %>
        <%= render "wrapped/slides/#{slide}", wrapped: @wrapped %>
      <% end %>
    <% end %>

    <div class="wrapped-hint">tap to continue</div>
  </div>
</div>
