<div class="wrapped-slide wrapped-slide--ships" data-wrapped-target="slide">
  <div class="wrapped-slide__content">
    <p class="wrapped-slide__eyebrow">your projects</p>
    <p class="wrapped-slide__emoji">🚀</p>
    <h2 class="wrapped-slide__stat"><%= wrapped.ships_count %></h2>
    <h1 class="wrapped-slide__headline"><%= "project".pluralize(wrapped.ships_count) %> shipped</h1>
    <% if wrapped.ships_count >= 3 %>
      <p class="wrapped-slide__body">you're on a roll, baker.</p>
    <% elsif wrapped.ships_count == 1 %>
      <p class="wrapped-slide__body">one down. many more to go.</p>
    <% else %>
      <p class="wrapped-slide__body">launch day is waiting for you.</p>
    <% end %>
  </div>
</div>
