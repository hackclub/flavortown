<div class="wrapped-slide wrapped-slide--complete" data-wrapped-target="slide">
  <div class="wrapped-slide__content">
    <p class="wrapped-slide__eyebrow">that's a wrap</p>
    <h1 class="wrapped-slide__headline">thanks for baking with us</h1>
    <p class="wrapped-slide__body">
      flavortown wouldn't be the same without <%= user.display_name %>.<br>
      see you next season.
    </p>
    <div class="wrapped-complete-actions">
      <button class="wrapped-btn" data-action="click->wrapped#download">download bento</button>
      <%= link_to "back to kitchen", root_path, class: "wrapped-btn" %>
    </div>
  </div>
</div>
