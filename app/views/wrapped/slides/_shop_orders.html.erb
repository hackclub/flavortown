<div class="wrapped-slide wrapped-slide--shop-orders" data-wrapped-target="slide">
  <div class="wrapped-bento wrapped-bento--2col">
    <div class="wrapped-bento__cell">
      <h2 class="wrapped-slide__stat"><%= wrapped.shop_orders_count %></h2>
      <h1 class="wrapped-slide__headline"><%= "order".pluralize(wrapped.shop_orders_count) %> placed</h1>
      <% if wrapped.shop_orders_count.zero? %>
        <p class="wrapped-slide__body">let's get ya more stuff next time!</p>
      <% else %>
        <p class="wrapped-slide__body">the shop missed you between visits.</p>
      <% end %>
    </div>
    <div class="wrapped-bento__cell wrapped-bento__cell--secondary">
      <p class="wrapped-slide__caption">cookies spent</p>
      <h2 class="wrapped-slide__stat"><%= number_with_delimiter(wrapped.cookies_spent) %></h2>
      <% if wrapped.fulfillment_team? || wrapped.fraud_dept? %>
        <p class="wrapped-slide__caption" style="margin-top: var(--space-s);">team fulfilled</p>
        <p class="wrapped-slide__body"><strong><%= number_with_delimiter(wrapped.orders_team_fulfilled) %></strong> orders</p>
      <% end %>
    </div>

    <% if wrapped.fraud_dept? %>
      <div class="wrapped-bento__cell wrapped-bento__cell--secondary wrapped-bento__cell--staff">
        <p class="wrapped-slide__caption">your fraud verdicts</p>
        <p class="wrapped-slide__body"><strong><%= wrapped.orders_personally_approved %></strong> approved, <strong><%= wrapped.orders_personally_rejected %></strong> rejected<% unless wrapped.fulfillment_team? %>, <strong><%= wrapped.orders_personally_held %></strong> held<% end %></p>
        <% if wrapped.orders_rank_fraud %>
          <p class="wrapped-slide__body"><strong>#<%= wrapped.orders_rank_fraud %></strong> on the fraud leaderboard</p>
        <% end %>
      </div>
    <% end %>

    <% if wrapped.fulfillment_team? %>
      <div class="wrapped-bento__cell wrapped-bento__cell--secondary wrapped-bento__cell--staff">
        <p class="wrapped-slide__caption">your fulfillments</p>
        <h2 class="wrapped-slide__stat"><%= number_with_delimiter(wrapped.orders_personally_fulfilled) %></h2>
        <% if wrapped.orders_rank_fulfillment %>
          <p class="wrapped-slide__body"><strong>#<%= wrapped.orders_rank_fulfillment %></strong> on the fulfillment leaderboard</p>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
