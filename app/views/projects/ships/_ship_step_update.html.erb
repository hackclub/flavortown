<div class="projects-ship__step">
  <h2 class="projects-ship__section-title">Write Your Ship Message</h2>
  <p class="projects-ship__section-desc">
    This is your moment! Tell the community what you built and what you learned.
  </p>

  <%= form_with(url: project_ships_path(@project), method: :post, id: "ship-form", local: true) do |form| %>
    <%= render InputComponent.new(
          label: "Ship message",
          placeholder: "I built a thing that does X! The hardest part was Y, but I figured it out by Z. Really happy with how it turned out :)",
          form: form,
          attribute: :ship_update,
          color: :yellow,
          subtitle: "What did you make? What was challenging? What are you proud of?",
          as: :text_area,
          input_html: { rows: 6, required: true }
        ) %>

    <%= render InputComponent.new(
          label: "Review Instructions (Optional)",
          placeholder: "Example: Run 'npm install && npm start' to launch locally. Test the multiplayer mode by opening two browser tabs. The AI features require an API key — use the demo key in the README.",
          form: form,
          attribute: :review_instructions,
          color: :blue,
          subtitle: "Help reviewers test your project. Include setup steps, test accounts, environment requirements, or anything they should know (max 2,000 characters).",
          as: :text_area,
          input_html: { rows: 4, maxlength: 2000 }
        ) %>

    <% if @active_sidequests.any? %>
      <% preselected_sidequest = if @project.space_themed?
                                   @active_sidequests.find { |sq| sq.slug == "challenger" }
                                 else
                                   @project.sidequests.find { |sq| @active_sidequests.include?(sq) }
                                 end %>
      <% preselected_sidequest_id = preselected_sidequest&.id %>
      <% sidequest_map = @active_sidequests.each_with_object({}) { |sq, acc| acc[sq.id.to_s] = sidequest_path(sq) } %>

      <div data-controller="sidequest-selector">
        <%= render InputComponent.new(
              label: "Sidequest",
              placeholder: "No sidequest",
              form: form,
              attribute: :sidequest_id,
              color: :blue,
              subtitle: "Choose one sidequest to submit this ship for.",
              as: :select,
              collection: @active_sidequests.map { |sidequest| [sidequest.title, sidequest.id] },
              input_html: {
                data: {
                  sidequest_selector_target: "select",
                  action: "change->sidequest-selector#selectChange"
                }
              },
              select_options: { include_blank: "No sidequest", selected: preselected_sidequest_id }
            ) %>

        <div class="projects-ship__sidequest-info" data-sidequest-selector-target="info" style="display: <%= preselected_sidequest_id.present? ? 'block' : 'none' %>;">
          <p class="projects-ship__sidequest-message">
            <strong>Before submitting:</strong> Check the <a href="#" data-sidequest-selector-target="link" class="projects-ship__sidequest-link" target="_blank" rel="noopener">sidequest details</a> to review the requirements and avoid rejection.
          </p>
        </div>

        <div data-sidequest-selector-target="sidequestMap" style="display: none;"><%= sidequest_map.to_json %></div>
      </div>
    <% end %>
  <% end %>
</div>
