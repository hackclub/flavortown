<div class="projects-ship__step projects-ship__step--with-video">
  <div class="projects-ship__step-main">
    <h2 class="projects-ship__section-title">Before You Ship</h2>
    <p class="projects-ship__section-desc">
      Make sure your project meets these requirements to qualify for a payout.
    </p>

    <% if @project.shadow_banned? %>
      <p class="projects-ship__requirements-error">
        Your project has been flagged by moderation and cannot be shipped.
        If you wish to appeal this decision, contact Fraud Squad on Slack.
      </p>
    <% end %>

    <div class="projects-ship__validations">
      <% @project.visual_shipping_requirements.each do |validation| %>
        <div class="projects-ship__validation <%= 'projects-ship__validation--passed' if validation[:passed] %>">
          <span class="projects-ship__validation-icon">
            <% if validation[:passed] %>
              <%= inline_svg_tag("icons/check_thick.svg") %>
            <% end %>
          </span>
          <span class="projects-ship__validation-label"><%=
            (validation[:passed] ? validation[:label] : (validation[:fail_label] || validation[:label])).html_safe
          %></span>
        </div>
      <% end %>
    </div>

    <% unless @project.shippable? %>
      <p class="projects-ship__requirements-warning">
        Complete all requirements above before you can continue to ship your project.
      </p>
    <% end %>
  </div>

  <div class="projects-ship__video-section">
    <%= render VimeoEmbedComponent.new(video: :what_is_a_ship) %>
  </div>
</div>
