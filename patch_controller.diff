--- app/controllers/sidequests_controller.rb
+++ app/controllers/sidequests_controller.rb
@@ -37,4 +37,27 @@
       render custom_template
     end
   end
+
+  def generate_ideas
+    api_key = ENV['GEMINI_API_KEY']
+    
+    if api_key.blank?
+      render json: { error: "Missing GEMINI_API_KEY environment variable" }, status: :internal_server_error
+      return
+    end
+
+    require 'net/http'
+    require 'uri'
+    require 'json'
+    
+    uri = URI("https://generativelanguage.googleapis.com/v1beta/models/gemma-2-27b-it:generateContent?key=#{api_key}")
+    
+    request = Net::HTTP::Post.new(uri)
+    request.content_type = "application/json"
+    request.body = JSON.dump({
+      "contents" => [{"role" => "user", "parts" => [{"text" => "Generate 1 cool Minecraft sidequest idea that involves coding (like a minecraft shader with retro vibe, or custom plugins). Keep it short, no more than 2 sentences. Be creative."}]}]
+    })
+    
+    response = Net::HTTP.start(uri.hostname, uri.port, use_ssl: true) do |http|
+      http.request(request)
+    end
+    
+    begin
+      result = JSON.parse(response.body)
+      text = result.dig("candidates", 0, "content", "parts", 0, "text") || "Could not generate ideas right now."
+      render json: { idea: text }
+    rescue
+      render json: { error: "Failed to parse API response" }, status: :internal_server_error
+    end
+  end
 end
